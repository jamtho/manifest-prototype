# -----------------------------------------------------------------------------
# 3g. DW — Cross-table identity & duality
# -----------------------------------------------------------------------------

dw:building_key_identity a mnf:SameEntity ;
    rdfs:label "BUILDING_NUMBER ≡ BUILDING_KEY ≡ FAC_BUILDING_KEY ≡ FCLT_BUILDING_KEY" ;
    rdfs:comment """All four columns hold the same string value
        ('NW32', 'W85ABC', etc.) for the same building. Joining across
        any pair works.""" ;
    mnf:identifyingColumn dw:bld_building_key ;
    mnf:identifyingColumn dw:fac_building_key ;
    mnf:identifyingColumn dw:fac_building_number ;
    mnf:identifyingColumn dw:fclt_building_key ;
    mnf:identifyingColumn dw:fclt_building_number ;
    mnf:identifyingColumn dw:far_building_key ;
    mnf:identifyingColumn dw:fclr_fclt_building_key ;
    mnf:identifyingColumn dw:spd_building_key ;
    mnf:identifyingColumn dw:fbla_building_key .

dw:fac_fclt_duality a mnf:KnownDeficiency ;
    rdfs:label "FAC_/FCLT_-prefixed parallel tables (duplicate data, renamed key columns)" ;
    mnf:deficiencyDescription """[BVT-K-GAP-11] Three tables describe MIT
        buildings and three describe rooms; multiple pairs are
        stylistic duplicates with renamed key columns:
        * fac_building (242) ≡ fclt_building (242) on 32 shared columns;
          differ in PK column name (FAC_BUILDING_KEY vs FCLT_BUILDING_KEY)
        * fac_floor (1079) ≡ fclt_floor (1079); same pattern
        * fac_building_address (785) ≡ fclt_building_address (785)
        * fac_rooms (43K) ≠ fclt_rooms (20K) — these DIVERGE
          (fac_ includes service/circulation spaces; fclt_ is curated)
        * space_detail (43K rows) is yet another room representation
          with its own schema""" ;
    mnf:impact "Either family generally yields the same answer for shared columns, but for diverging tables (e.g. fac_rooms vs fclt_rooms) the row sets differ — the consumer needs to choose deliberately." ;
    mnf:severity mnf:Moderate .

dw:building_name_disagreement a mnf:KnownDeficiency ;
    rdfs:label "Three building-name columns disagree" ;
    mnf:deficiencyDescription """[BVT-K-GAP-8] For building 32:
        * buildings.BUILDING_NAME = 'Stata Center' (proper case)
        * fclt_building.BUILDING_NAME = 'STATA CENTER' (uppercase)
        * fclt_building.BUILDING_NAME_LONG = 'Ray and Maria Stata Center'
        Same conceptual attribute, different stylistic conventions.
        SameEntity is the wrong fit (values don't match for joining).
        Convention isn't perfectly consistent — for W64,
        BUILDING_NAME_LONG degrades to 'Building W64'.""" ;
    mnf:impact "When asked for 'the building name', the consumer has to choose one of the three columns deliberately — there's no universal right answer." ;
    mnf:severity mnf:Moderate .


# -----------------------------------------------------------------------------
# 3h. DW — Composite-key derivations
# -----------------------------------------------------------------------------

dw:derive_fac_room_key a mnf:Derivation ;
    rdfs:label "FAC_ROOM_KEY = '<BUILDING_KEY>-<ROOM>'" ;
    mnf:derivedColumn dw:far_room_key ;
    mnf:sourceColumn dw:far_building_key ;
    mnf:sourceColumn dw:far_room ;
    mnf:derivationFunction bvtk:DashConcat ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Invertible .

dw:derive_fclt_room_key a mnf:Derivation ;
    rdfs:label "FCLT_ROOM_KEY = '<FCLT_BUILDING_KEY>-<ROOM>'" ;
    mnf:derivedColumn dw:fclr_room_key ;
    mnf:sourceColumn dw:fclr_fclt_building_key ;
    mnf:sourceColumn dw:fclr_room ;
    mnf:derivationFunction bvtk:DashConcat ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Invertible .

dw:derive_fclt_address_key a mnf:Derivation ;
    rdfs:label "FCLT_BUILDING_ADDRESS_KEY = '<BUILDING>-<ADDRESS_PURPOSE>'" ;
    mnf:derivedColumn dw:fbla_address_key ;
    mnf:sourceColumn dw:fbla_building_key ;
    mnf:sourceColumn dw:fbla_address_purpose ;
    mnf:derivationFunction bvtk:DashConcat ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Invertible .

bvtk:DashConcat a rdfs:Resource ;
    rdfs:label "Dash-separated string concatenation" .


# -----------------------------------------------------------------------------
# 3i. DW — Provenance and known deficiencies
# -----------------------------------------------------------------------------

dw:dw_provenance a mnf:Provenance ;
    mnf:source <https://ist.mit.edu/warehouse> ;
    mnf:sourceDescription """MIT institutional data warehouse. Real
        institutional data — building names, dates, lat/lon, named-for
        attributions all retained. Multiple upstream systems integrated
        (CIS, SIS, HR, Drupal, Moira, IAP, TIP, ZPM, etc.). Some
        Oracle-flavoured idioms persist in column types and date
        formats from the upstream warehouse loader.""" ;
    mnf:hasTransformation [
        a mnf:Transformation ;
        mnf:transformationType "warehouse_load" ;
        mnf:transformationDescription """Warehouse loaders pull from
            upstream systems on differing schedules. WAREHOUSE_LOAD_DATE
            in many tables records the load date in Oracle 'DD-MON-YY'
            format (e.g. '19-DEC-24')."""
    ] ;
    mnf:hasTransformation [
        a mnf:Transformation ;
        mnf:transformationType "no_anonymisation" ;
        mnf:transformationDescription "[BVT-K-GAP-9] No anonymisation applied to dw."
    ] .

dw:deficiency_no_declared_keys a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-17] No PRIMARY KEY or FOREIGN
        KEY declarations are present in upstream/dev_tables.json for
        any dw table. Relationships have to be inferred from
        upstream/dw_join_keys.json (1034 join-key pairs) plus knowledge
        investigations. Every FK in the dw section above is a soft FK
        [BVT-K-GAP-4].""" ;
    mnf:impact "A model that relies on FK declarations to plan joins gets nothing useful. Join knowledge has to come from documented patterns." ;
    mnf:severity mnf:Severe .

dw:deficiency_dw_dialect a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-12] Column types in
        upstream/dev_tables.json use Oracle types (VARCHAR2, NUMBER,
        DATE) but the live database is MySQL (varchar, int, datetime).
        The CREATE TABLE strings the prompt builder renders are
        Oracle-flavoured even though they're executed against MySQL.
        Same root cause as the bvt_description.ttl
        deficiency_dialect_mismatch.""" ;
    mnf:impact "Models may produce Oracle-dialect SQL that fails on MySQL." ;
    mnf:severity mnf:Moderate .

dw:deficiency_dw_date_strings a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-10] Many dw date columns are
        stored as VARCHAR with one of two formats:
        * MM/DD/YYYY ('07/01/1913') — DATE_BUILT, DATE_OCCUPIED, DATE_ACQUIRED
        * DD-MON-YY ('19-DEC-24') — WAREHOUSE_LOAD_DATE
        Filtering on a date range needs string parsing. Naive
        comparisons (DATE_BUILT < '1950-01-01') return wrong results
        because the column isn't a real date.""" ;
    mnf:impact "Date-range filters need string parsing (e.g. CAST(SUBSTR(DATE_BUILT,-4) AS UNSIGNED) for the year, or STR_TO_DATE for full-date comparisons). Naive string comparisons against date literals silently return wrong results." ;
    mnf:severity mnf:Severe .

dw:deficiency_postal_code_stripped a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-10] POSTAL_CODE in
        fac_/fclt_building_address has leading zeros stripped:
        Cambridge MA 02139 stored as '2139'. Joining to
        zip_usa.ZIP_CODE (which probably stores '02139') would need
        zero-padding back via LPAD or string concatenation.""" ;
    mnf:impact "Direct join on POSTAL_CODE = ZIP_CODE will miss most rows." ;
    mnf:severity mnf:Moderate .

dw:deficiency_dw_unmodelled a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """Some tables in dw are present as
        schema-only stubs (column names + types) without rich annotation
        — anonymisation flags, cross-namespace bridges, sentinel values,
        case conventions, etc. See PART X (Schema stubs) for the full
        list.""" ;
    mnf:impact "Queries against stub tables work from schema alone but lack the data-shape guidance carried by the richly-annotated tables." ;
    mnf:severity mnf:Moderate .

dw:deficiency_database_metadata_hack a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-19] dw:DatabaseCatalogue is a
        Manifest Dataset by necessity, not by fit. mnf has no concept of
        "database-level metadata" (table list, cluster taxonomy, prefix
        legend, top-table-hit counts). We model it as a synthetic
        dataset where each row is one table in dw — the columns describe
        per-table structural facts, but no row-level data is loaded. The
        narrative facts (cluster sizes, prefix conventions) live in the
        rdfs:comment because they don't fit any column.""" ;
    mnf:impact "Consumers querying the manifest graph for 'datasets' will see DatabaseCatalogue alongside real tables, which is misleading. SPARQL queries that distinguish 'real' from 'meta' need a custom predicate." ;
    mnf:severity mnf:Minor .


# =============================================================================
# PART 3 (continued): DW — non-facilities clusters
# =============================================================================
#
# The earlier section covered the facilities cluster (buildings, rooms,
# floors, space-*). This section covers the remaining structurally-rich
# clusters: departments + DLC org tree, subjects + courses + catalogues,
# IAP, library + TIP, people, terms + time, and Moira. Domain semantic
# types are introduced as needed; cross-cluster FKs and SameEntity
# declarations are at the end of the section.
#
# Tables included here are described with the columns most likely to be
# referenced in joins, filters, or projections — typically all key columns
# plus the most informational non-key columns. Tables not present in this
# section either belong to no investigated cluster (lookup / history /
# mirror tables — see "Schema stubs" near the end) or carry no rich
# annotation worth lifting beyond their schema.
# =============================================================================

# -----------------------------------------------------------------------------
# 3j. DW domain semantic types (extended)
# -----------------------------------------------------------------------------

dw:DLCKey a mnf:SemanticType ;
    rdfs:label "DLC Key (Department/Lab/Center)" ;
    rdfs:comment """Always 'D_<UPPERCASE>'. Real institutional codes
        (D_HISTORY, D_CSAIL, D_PHYSICS, D_DOF). DLC_KEY = DLC_CODE in
        master_dept_hierarchy. A few oddities: D_BF&T (ampersand),
        D_PROVOST_AREA (more a hierarchy marker), D_OBSOLETE /
        D_UNDEF_DEFUNCT (catch-all buckets).""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:TermCode a mnf:SemanticType ;
    rdfs:label "Academic Term Code" ;
    rdfs:comment """Format <YEAR><SEASON_2CHAR>. Seasons: FA (Fall),
        JA (January/IAP), SP (Spring), SU (Summer). 133 distinct values
        in subject_offered ranging '1986FA' through '2025SP'. Used by
        subject_offered, library_subject_offered, tip_subject_offered,
        academic_terms_all, etc. Don't do arithmetic on this — convert
        via academic_terms_all.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:SubjectId a mnf:SemanticType ;
    rdfs:label "MIT Subject ID" ;
    rdfs:comment """Format <COURSE>.<NUMBER>. Course codes can be numeric
        ('6', '12') or alphabetic ('EC', 'HAA', 'STS', 'PE'). Subject
        numbers can have letter prefixes ('UR' Undergraduate Research,
        'S' Special). Examples: '6.147', '12.UR', 'HAA.6824'. The dot
        is part of the identifier; LIKE '6.%' overmatches.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:MITID_NamespaceA a mnf:SemanticType ;
    rdfs:label "MIT_ID — Namespace A (employee_directory etc.)" ;
    rdfs:comment """9-digit anonymised MIT identifier.
        Namespace A appears in: employee_directory,
        drupal_employee_directory, subject_offered.RESPONSIBLE_FACULTY_MIT_ID,
        subject_offered_summary.RESPONSIBLE_FACULTY_MIT_ID,
        moira_list_detail.MOIRA_LIST_MEMBER_MIT_ID,
        space_supervisor_usage.MIT_ID. Do NOT join to Namespace B —
        returns 0 rows.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:identifierNamespace "dw/mit_id/A" .

dw:MITID_NamespaceB a mnf:SemanticType ;
    rdfs:label "MIT_ID — Namespace B (se_person etc.)" ;
    rdfs:comment """9-digit anonymised MIT identifier,
        DISJOINT from Namespace A. Appears in: se_person,
        hr_faculty_roster, warehouse_users. Cross-walk to Namespace A
        only via KRB_NAME or FULL_NAME.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:identifierNamespace "dw/mit_id/B" .

dw:KrbName a mnf:SemanticType ;
    rdfs:label "Kerberos / Athena Username" ;
    rdfs:comment """[BVT-K-GAP-25] 2-9 char username. Casing
        inconsistent across tables: lowercase in employee_directory,
        moira_list_detail, roles_fin_pa; UPPERCASE in
        person_auth_area.USER_NAME. Joins need UPPER() or LOWER()
        normalisation.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:YNFlag a mnf:SemanticType ;
    rdfs:label "'Y'/'N' string flag" ;
    rdfs:comment """Single-char string boolean used pervasively in dw.
        Values are LITERAL 'Y' and 'N' strings, not booleans. Filtering
        on `= 1` or `= TRUE` returns 0 rows.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "Y" ;
        mnf:allowedValue "N"
    ] .

dw:SchoolCode a mnf:SemanticType ;
    rdfs:label "MIT School Code (single letter)" ;
    rdfs:comment """Single-letter school code. A=Architecture+Planning,
        E=Engineering, H=HASS, M=Sloan/Mgmt, S=Science,
        W=Schwarzman College of Computing, T=Whitaker/HST,
        Y=MIT-academic-other, X=MIT-non-academic, Z=Non-MIT.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "A" ;
        mnf:allowedValue "E" ;
        mnf:allowedValue "H" ;
        mnf:allowedValue "M" ;
        mnf:allowedValue "S" ;
        mnf:allowedValue "W" ;
        mnf:allowedValue "T" ;
        mnf:allowedValue "Y" ;
        mnf:allowedValue "X" ;
        mnf:allowedValue "Z"
    ] .

dw:HGNCode a mnf:SemanticType ;
    rdfs:label "Hierarchical Group Number (graduate-credit classification)" ;
    rdfs:comment """G = Graduate program, H = Higher-level graduate,
        N = Not for graduate credit. Sometimes 'U' (Undergraduate)
        appears in cis_course_catalog.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "G" ;
        mnf:allowedValue "H" ;
        mnf:allowedValue "N" ;
        mnf:allowedValue "U"
    ] .

dw:CourseLevel a mnf:SemanticType ;
    rdfs:label "Course Level" ;
    rdfs:comment "G = Graduate, U = Undergraduate." ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "G" ;
        mnf:allowedValue "U"
    ] .

dw:OracleDateString a mnf:SemanticType ;
    rdfs:label "Date as Oracle DD-MON-YY string" ;
    rdfs:comment """[BVT-K-GAP-10] Same shape as bvtk:OracleShortDateString.
        Used by TERM_START_DATE, WAREHOUSE_LOAD_DATE, HOLIDAY_CLOSING_DATE,
        SESSION_DATE (IAP), LAST_ACTIVITY_DATE, etc. Parse via
        STR_TO_DATE(col, '%d-%b-%y').""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:CommaListString a mnf:SemanticType ;
    rdfs:label "Comma-separated list in a varchar" ;
    rdfs:comment """[BVT-K-GAP-21] Varchar containing a comma-separated
        list (often comma-space). Used by space_supervisor_usage.
        DEPT_NAMES, subject_offered.CLUSTER_LIST,
        course_catalog.JOINT_SUBJECTS, etc. Splitting needs
        SUBSTRING_INDEX or string-array unnesting.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:SentinelTermCode a mnf:SemanticType ;
    rdfs:label "TERM_CODE with '000000' / '999999' sentinels" ;
    rdfs:comment """[BVT-K-GAP-5] Most TERM_CODE columns hold
        <YEAR><SEASON> values, but FROM_TERM and THRU_TERM in
        sis_course_description and student_degree_program use
        '000000' (Beginning of Time) and '999999' (End of Time)
        sentinel strings. The companion *_DESCRIPTION columns spell
        these out literally.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:HASSAttribute a mnf:SemanticType ;
    rdfs:label "HASS / GIR Attribute Code" ;
    rdfs:comment """Distribution-requirement codes. 17 values across
        post-2010 HASS_ATTRIBUTE (HE, HS, HA, HH, etc.) and pre-2010
        GIR_ATTRIBUTE (HD1-HD5, HDL). Some codes (e.g. 'HE') appear in
        BOTH systems. Comma-list values like 'HA,HH' are also valid
        for cross-attributed subjects.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:GIRAttribute a mnf:SemanticType ;
    rdfs:label "General Institute Requirement Attribute" ;
    rdfs:comment """REST (Rest Elec in Sci & Tech), LAB (Institute Lab),
        CHEM, CAL1, CAL2, BIOL, PHY1, PHY2, plus the older HD1-HD5 for
        pre-Fall-2010 students.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:OwnerType a mnf:SemanticType ;
    rdfs:label "Moira Owner Type" ;
    rdfs:comment """4 distinct values. Concatenated as a prefix to
        OWNER name in MOIRA_LIST_OWNER_KEY (no delimiter — see
        BVT-K-GAP-29).""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "LIST" ;
        mnf:allowedValue "USER" ;
        mnf:allowedValue "KERBEROS" ;
        mnf:allowedValue "NONE"
    ] .

dw:CIPCode a mnf:SemanticType ;
    rdfs:label "Federal CIP Program Code (6-digit)" ;
    rdfs:comment "US Department of Education Classification of Instructional Programs. 6-digit string. Editions: 1990, 2000, 2010, 2020." ;
    mnf:requiredPhysicalType mnf:Varchar .


# -----------------------------------------------------------------------------
# 3k. DW Departments + Orgs cluster
# -----------------------------------------------------------------------------

dw:master_dept_hierarchy a mnf:Dataset ;
    rdfs:label "dw.master_dept_hierarchy — DLC org tree (5-level path)" ;
    rdfs:comment """The canonical org tree, one row per DLC. Stores a
        flattened self-contained path through 5 hierarchy levels.
        Level 5 is NEVER populated in this dump. DLC_NAME is mixed-case;
        case-insensitive comparisons need LOWER()/UPPER().""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:mdh_dlc_key ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:mdh_dlc_key , dw:mdh_dlc_code , dw:mdh_dlc_name ,
        dw:mdh_hierarchy_type ,
        dw:mdh_l1_code , dw:mdh_l1_name ,
        dw:mdh_l2_code , dw:mdh_l2_name ,
        dw:mdh_l3_code , dw:mdh_l3_name ,
        dw:mdh_l4_code , dw:mdh_l4_name ,
        dw:mdh_l5_code , dw:mdh_l5_name ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/master_dept_hierarchy" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 310 ;
    mnf:hasKnownDeficiency dw:deficiency_mdh_level5_empty .

dw:mdh_dlc_key a mnf:Column ;
    mnf:columnName "DLC_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:DLCKey ;
    mnf:nullable false .

dw:mdh_dlc_code a mnf:Column ;
    mnf:columnName "DLC_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:DLCKey ;
    mnf:nullable false ;
    rdfs:comment "Always equal to DLC_KEY — same value, two columns." .

dw:mdh_dlc_name a mnf:Column ;
    mnf:columnName "DLC_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Human-readable description ('History', 'CSAIL'). Real, not anonymised." .

dw:mdh_hierarchy_type a mnf:Column ;
    mnf:columnName "HIERARCHY_TYPE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Always 'Standard Hierarchy' — uninformative." ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "Standard Hierarchy"
    ] .

dw:mdh_l1_code a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_1_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Always 'D_ALL' — root, single value." .

dw:mdh_l1_name a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_1_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Always 'All Departments'." .

dw:mdh_l2_code a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_2_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:mdh_l2_name a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_2_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "8 distinct values: Provost Area, President's area, Executive Vice President's Area, Miscellaneous Institute Related, Other institutions outside of MIT, Outside organizations affiliated with MIT, Obsolete DLC codes, Undefined or defunct." .

dw:mdh_l3_code a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_3_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:mdh_l3_name a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_3_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-8] School name; differs in spelling from sis_department.SCHOOL_NAME (e.g. 'School of Humanities & Social Science' here vs 'Hum, Arts & Social Sciences' there)." .

dw:mdh_l4_code a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_4_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Populated for ~9 of 310 rows." .

dw:mdh_l4_name a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_4_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:mdh_l5_code a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_5_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-2] NEVER populated in this dump — column exists but always NULL." .

dw:mdh_l5_name a mnf:Column ;
    mnf:columnName "MASTER_DEPT_HIER_LEVEL_5_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-2] Always NULL." .


dw:master_dept_hierarchy_links a mnf:Dataset ;
    rdfs:label "dw.master_dept_hierarchy_links — DLC↔external-system cross-refs" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 42,089. Cross-
        references DLCs to identifiers in other systems via
        LINK_TYPE_CODE (FC=Funds Center 34555 rows, PMIT=Profit Center
        4366, ORG2=New Org Unit 1096, ORGU=Old Org Unit 922, BAG=NIMBUS
        BAG 528, FORG=Facilities Org 330).""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:mdhl_dlc_key , dw:mdhl_link_type_code , dw:mdhl_link_type ,
        dw:mdhl_linked_object_key , dw:mdhl_linked_object_code ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/master_dept_hierarchy_links" ;
    mnf:rowCountSnapshot 42089 ;
    mnf:hasProvenance dw:dw_provenance .

dw:mdhl_dlc_key a mnf:Column ;
    mnf:columnName "DLC_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:DLCKey ;
    mnf:nullable false .

dw:mdhl_link_type_code a mnf:Column ;
    mnf:columnName "LINK_TYPE_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "FC" ;
        mnf:allowedValue "PMIT" ;
        mnf:allowedValue "ORG2" ;
        mnf:allowedValue "ORGU" ;
        mnf:allowedValue "BAG" ;
        mnf:allowedValue "FORG"
    ] .

dw:mdhl_link_type a mnf:Column ;
    mnf:columnName "LINK_TYPE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Spelled-out form ('Standard Funds Center', 'PCMIT-0 Profit Center')." .

dw:mdhl_linked_object_key a mnf:Column ;
    mnf:columnName "LINKED_OBJECT_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
