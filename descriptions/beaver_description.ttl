dw:employee_directory a mnf:Dataset ;
    rdfs:label "dw.employee_directory — MIT phonebook (Namespace A)" ;
    rdfs:comment """[BVT-K-GAP-1 / BVT-K-GAP-22] Snapshot row count: 17,763. THE canonical join target for
        subject_offered.RESPONSIBLE_FACULTY_MIT_ID (Namespace A).
        Email domains all anonymised (worker.com, gmail.business.com,
        etc.) — NO @mit.edu addresses survive.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:ed_mit_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:ed_mit_id , dw:ed_full_name , dw:ed_first_name , dw:ed_last_name ,
        dw:ed_krb_name , dw:ed_krb_name_uppercase ,
        dw:ed_email_address , dw:ed_email_address_uppercase ,
        dw:ed_office_location , dw:ed_office_phone , dw:ed_department_number ,
        dw:ed_hr_org_unit_id , dw:ed_hr_org_unit_title ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/employee_directory" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 17763 ;
    mnf:hasKnownDeficiency dw:deficiency_anonymised_emails .

