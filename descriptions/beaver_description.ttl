    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "MIT FY starts July 1 (FY2025 runs Jul 2024 - Jun 2025)." .

dw:tday_calendar_period a mnf:Column ;
    mnf:columnName "CALENDAR_PERIOD" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Format <CY><MM>: '202412' = December 2024." .

dw:tday_calendar_period_description a mnf:Column ;
    mnf:columnName "CALENDAR_PERIOD_DESCRIPTION" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
