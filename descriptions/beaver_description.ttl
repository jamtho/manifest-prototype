dw:sd_school_code a mnf:Column ;
    mnf:columnName "SCHOOL_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:SchoolCode ;
    mnf:nullable true .

dw:sd_school_name a mnf:Column ;
    mnf:columnName "SCHOOL_NAME" ;
    mnf:physicalType mnf:Varchar ;
