# --- New deficiencies ---

dw:deficiency_mdh_level5_empty a mnf:KnownDeficiency ;
    mnf:deficiencyDescription "[BVT-K-GAP-2] master_dept_hierarchy.MASTER_DEPT_HIER_LEVEL_5_CODE/_NAME columns exist but are NULL for every row in this dump." ;
    mnf:impact "Joins on level 5 return zero rows." ;
    mnf:severity mnf:Minor .

dw:deficiency_school_name_disagreement a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-8] sis_department.SCHOOL_NAME
        and master_dept_hierarchy.MASTER_DEPT_HIER_LEVEL_3_NAME spell
        the same school differently:
          sis_department:        'Hum, Arts & Social Sciences'
          master_dept_hierarchy: 'School of Humanities & Social Science' (singular!)
        Equality filters that use one spelling won't match rows in the
        other.""" ;
    mnf:impact "A school-name filter has to use the spelling found in the table being queried; cross-table joins on the school-name string return zero rows." ;
    mnf:severity mnf:Moderate .

dw:deficiency_cluster_type_blip a mnf:KnownDeficiency ;
    mnf:deficiencyDescription "subject_offered.CLUSTER_TYPE has 268 rows with a single-space ' ' value — a data-quality blip distinct from NULL or any documented code." ;
    mnf:impact "Filters on the documented codes (S/J/M/NULL) miss these rows." ;
    mnf:severity mnf:Minor .

dw:deficiency_subject_summary_three_way a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-26] Three nearly-identical
        per-(subject, term) summary tables exist:
          subject_offered (649K rows, 47 cols, base — per-section)
          subject_offered_summary (470K rows, 29 cols, per-subject; carries faculty)
          subject_summary (469K rows, 41 cols, per-subject; carries SUBJECT_OR_CLUSTER)
        Each table has a different grain (per-section vs per-subject) and
        a different column set. Picking the right one depends on the
        question — the manifest can't yet express table-selection rules
        (see GAP-26 in vocabulary-evolution.md).""" ;
    mnf:impact "A consumer can write correct SQL against the wrong-grain table and get different row counts than expected." ;
    mnf:severity mnf:Moderate .

dw:deficiency_course_catalog_three_way a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """Three course-catalog tables exist with
        overlapping but different content:
          course_catalog_subject_offered (20K rows, recent year-scoped)
          cis_course_catalog (115K rows, longer history)
          drupal_course_catalog (122K rows, Drupal-published mirror)
        Core column names match across all three; swapping the FROM is a
        one-table change.""" ;
    mnf:impact "Picking the wrong catalogue under-/over-counts subjects, especially for date-bounded queries." ;
    mnf:severity mnf:Moderate .

dw:deficiency_typo_column a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-28] sis_course_description has
        BOTH GRADAUTE_LEVEL (typo) and GRADUATE_LEVEL columns. Both
        contain identical values. Probably preserved for backwards-
        compatibility with old code.""" ;
    mnf:impact "Either column works; the typo isn't enforced anywhere." ;
    mnf:severity mnf:Minor .

dw:deficiency_iap_single_term a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-24] iap_subject_detail (and
        the rest of the IAP cluster) is a SINGLE-TERM SNAPSHOT — every
        row has TERM_CODE='2021JA'. Schema looks multi-term but data
        only covers IAP 2021.""" ;
    mnf:impact "Queries about IAP 2024 etc. return zero rows. Schema doesn't constrain this — model has to know empirically." ;
    mnf:severity mnf:Moderate .

dw:deficiency_anonymised_emails a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """employee_directory.EMAIL_ADDRESS values
        are anonymised — no @mit.edu addresses survive. Domains:
        worker.com (12K), gmail.business.com (4K), employee.com,
        hotmail.com, referer.com.""" ;
    mnf:impact "Cannot infer real institutional addresses; queries that filter on @mit.edu get zero rows." ;
    mnf:severity mnf:Minor .

dw:deficiency_day_of_week_padded a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-20] time_day.DAY_OF_WEEK is
        stored as char(9) padded with trailing spaces ('Friday   ',
        'Sunday   '). WHERE DAY_OF_WEEK = 'Friday' returns 0 rows;
        needs RTRIM, LIKE 'Friday%', or the literal padded form.""" ;
    mnf:impact "Naive equality filters miss every row." ;
    mnf:severity mnf:Moderate .

dw:deficiency_holiday_mit_prefix a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """mit_holiday_closing_calendar.HOLIDAY_CLOSING_DESCRIPTION
        prepends 'MIT ' to every Standard Holiday name ('MIT Christmas
        Day'). Filtering on 'Christmas Day' without the prefix returns
        0 rows. Emergency / Special closings have description set to
        the literal 'EMER' or 'SHOL' instead.""" ;
    mnf:impact "Holiday-name filters need to know the 'MIT ' prefix and the EMER/SHOL sentinels." ;
    mnf:severity mnf:Moderate .

dw:deficiency_moira_duplicates a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-1] moira_list has 100,000
        rows but only 58,071 distinct MOIRA_LIST_KEY values — same list
        appears up to 4× with different flag combinations (looks like
        SCD-style snapshots folded together). USE SELECT DISTINCT
        before joining.""" ;
    mnf:impact "Joins multiply rows; counts inflate. Models that don't dedupe report incorrect numbers." ;
    mnf:severity mnf:Moderate .

dw:deficiency_moira_no_op_filters a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """[BVT-K-GAP-13] moira_list.IS_ACTIVE is
        constant 'Y' (filter is no-op); IS_HIDDEN is constant 'N'
        (filter is no-op).""" ;
    mnf:impact "Adding these filters changes nothing — the columns are constant in this dump. SQL that includes them is non-functional but not incorrect." ;
    mnf:severity mnf:Minor .

dw:deficiency_moira_orphan_memberships a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """8,023 list keys appear in
        moira_list_detail but not in moira_list (orphan memberships).
        Conversely, 39,511 list keys (68% of distinct moira_list keys)
        have ZERO member rows in detail.""" ;
    mnf:impact "Inner joins drop orphans silently; outer joins surface the asymmetry." ;
    mnf:severity mnf:Minor .

dw:deficiency_tip_status_blips a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """tip_material_status has 12 rows but
        4 of them ('NL', 'NS', 'NB', '  ') have NULL descriptions.
        One key is the literal two-space string '  '.""" ;
    mnf:impact "Filters on description = '...' miss these rows; key matching needs the literal '  '." ;
    mnf:severity mnf:Minor .




# =============================================================================
# PART 3 (continued): DW — schema stubs
# =============================================================================
#
# Schema-only declarations for dw tables that don't yet have rich
# investigations behind them. Each stub gives column names and types so
# that the schema is queryable from the graph and basic SELECTs can be
# planned, but carries no semantic types, no derivations, no
# anonymisation flags, no case conventions, no FK declarations, no
# known-deficiency annotations beyond the row-count snapshot. These
# fields are exactly the kind of thing a follow-up investigation can
# add. Stubs are grouped into:
#
#   * Empty tables — zero rows in this dump. Schema present but no data.
#     Annotated `mnf:rowCountSnapshot 0`.
#   * SCD-2 history tables — `*_hist` family. The vocabulary doesn't yet
#     have a clean way to express SCD-2 row semantics (effective_from /
#     effective_to / live-row markers); these stubs carry the schema only.
#   * Cross-system mirror tables — same logical content as a sibling
#     table, different upstream system / publishable subset.
#   * Reference / lookup tables — standard small-cardinality lookups. 
#
# To upgrade a stub to a full description, replace its block with one
# patterned after the rich tables in PART 3 above (semantic types on
# columns, derivations where applicable, deficiencies, etc.).
#
# Column URI convention for stubs: `dw:<table>__<col_lower>` (double
# underscore between table and column). When a stub is upgraded to a
# rich description, the curator can either keep this convention or
# rename to a shorter abbreviation matching the table's investigation.
# =============================================================================


