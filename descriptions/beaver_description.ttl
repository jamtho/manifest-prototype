    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/sis_department" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 128 ;
    mnf:hasKnownDeficiency dw:deficiency_school_name_disagreement .

dw:sd_department_code a mnf:Column ;
    mnf:columnName "DEPARTMENT_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Short code, mix of numeric ('13') and alphabetic ('IDS', 'ESD')." .

dw:sd_department_name a mnf:Column ;
    mnf:columnName "DEPARTMENT_NAME" ;
