dw:subject_offered a mnf:Dataset ;
    rdfs:label "dw.subject_offered — subject sections per term" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 649,440. One row
        per (term, subject, section). 47 columns total; the most
        information-rich subjects table. RESPONSIBLE_FACULTY_MIT_ID is in
        MIT_ID Namespace A.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:so_term_code , dw:so_subject_id , dw:so_subject_title ,
        dw:so_master_subject_id , dw:so_composite_subject_key ,
        dw:so_section_id , dw:so_is_master_section , dw:so_is_lecture_section ,
        dw:so_offer_dept_code , dw:so_offer_dept_name , dw:so_offer_school_name ,
        dw:so_responsible_faculty_name , dw:so_responsible_faculty_mit_id ,
        dw:so_meet_time , dw:so_meet_place ,
        dw:so_cluster_type , dw:so_cluster_list ,
        dw:so_hgn_code , dw:so_hgn_code_desc ,
        dw:so_subject_offered_summary_key , dw:so_subject_grouping_key ,
        dw:so_subject_enrollment_number , dw:so_section_enrollment_number ,
        dw:so_num_enrolled_students ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/subject_offered" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 649440 ;
