# --- Foreign keys ---

dw:fk_so_to_employee a mnf:ForeignKey ;
    rdfs:label "subject_offered.RESPONSIBLE_FACULTY_MIT_ID → employee_directory.MIT_ID (Namespace A)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:so_responsible_faculty_mit_id ;
    mnf:foreignKeyTo dw:ed_mit_id ;
    mnf:referentialIntegrity mnf:PartialIntegrity ;
    rdfs:comment "[BVT-K-GAP-4 / BVT-K-GAP-22] Soft FK. ~2,245 distinct ids resolve. Joining to se_person.MIT_ID instead returns 0 rows." .

dw:fk_sos_to_employee a mnf:ForeignKey ;
    rdfs:label "subject_offered_summary.RESPONSIBLE_FACULTY_MIT_ID → employee_directory.MIT_ID" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:sos_responsible_faculty_mit_id ;
    mnf:foreignKeyTo dw:ed_mit_id ;
    mnf:referentialIntegrity mnf:PartialIntegrity .

dw:fk_mld_to_employee a mnf:ForeignKey ;
    rdfs:label "moira_list_detail.MEMBER_MIT_ID → employee_directory.MIT_ID (Namespace A)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:mld_member_mit_id ;
    mnf:foreignKeyTo dw:ed_mit_id ;
    mnf:referentialIntegrity mnf:PartialIntegrity ;
    rdfs:comment "[BVT-K-GAP-4 / BVT-K-GAP-22] 6,530 distinct matches. Joining to se_person.MIT_ID instead returns 0." .

dw:fk_mld_to_owner a mnf:ForeignKey ;
    rdfs:label "moira_list_detail.OWNER_KEY → moira_list_owner.OWNER_KEY (clean — no orphans)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:mld_owner_key ;
    mnf:foreignKeyTo dw:mlo_key ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "All 13,037 detail-referenced owner-keys exist in moira_list_owner." .

dw:fk_mld_to_list a mnf:ForeignKey ;
    rdfs:label "moira_list_detail.LIST_KEY → moira_list.LIST_KEY (PARTIAL — orphans both ways)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:mld_list_key ;
    mnf:foreignKeyTo dw:ml_key ;
    mnf:referentialIntegrity mnf:PartialIntegrity ;
    rdfs:comment "8,023 detail keys not in moira_list; 39,511 list keys (68%) have ZERO members." .

dw:fk_sd_to_mdh a mnf:ForeignKey ;
    rdfs:label "sis_department.DLC_KEY → master_dept_hierarchy.DLC_KEY" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:sd_dlc_key ;
    mnf:foreignKeyTo dw:mdh_dlc_key ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

dw:fk_fodk_to_mdh a mnf:ForeignKey ;
    rdfs:label "fclt_org_dlc_key.DLC_KEY → master_dept_hierarchy.DLC_KEY" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:fodk_dlc_key ;
    mnf:foreignKeyTo dw:mdh_dlc_key ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

dw:fk_fodk_to_fo a mnf:ForeignKey ;
    rdfs:label "fclt_org_dlc_key.FCLT_ORGANIZATION_KEY → fclt_organization.FCLT_ORGANIZATION_KEY" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:fodk_organization_key ;
    mnf:foreignKeyTo dw:fo_organization_key ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

dw:fk_so_to_term a mnf:ForeignKey ;
    rdfs:label "subject_offered.TERM_CODE → academic_terms_all.TERM_CODE" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:so_term_code ;
    mnf:foreignKeyTo dw:ata_term_code ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

dw:fk_isd_to_term a mnf:ForeignKey ;
    rdfs:label "iap_subject_detail.TERM_CODE → academic_terms_all.TERM_CODE" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:isd_term_code ;
    mnf:foreignKeyTo dw:ata_term_code ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

dw:fk_at_to_ata a mnf:ForeignKey ;
    rdfs:label "academic_terms.TERM_CODE → academic_terms_all.TERM_CODE (subset)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:at_term_code ;
    mnf:foreignKeyTo dw:ata_term_code ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "academic_terms is a strict subset of academic_terms_all." .

dw:fk_paa_to_krb a mnf:ForeignKey ;
    rdfs:label "person_auth_area.USER_NAME → employee_directory.KRB_NAME_UPPERCASE" ;
    mnf:declared false ;
    mnf:foreignKeyFrom dw:paa_user_name ;
    mnf:foreignKeyTo dw:ed_krb_name_uppercase ;
    mnf:referentialIntegrity mnf:PartialIntegrity ;
