# -----------------------------------------------------------------------------
# 3q. DW Moira cluster
# -----------------------------------------------------------------------------

dw:moira_list a mnf:Dataset ;
    rdfs:label "dw.moira_list — Moira mailing-list catalogue (with DUPLICATES)" ;
    rdfs:comment """Only 58,071 distinct MOIRA_LIST_KEY values across the
        100,000 rows — duplicates appear up to 4× with different flag
        combos (SCD-style snapshots folded together). USE DISTINCT before
        joining. MOIRA_LIST_DESCRIPTION is uniformly NULL.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:ml_key , dw:ml_name , dw:ml_description ,
        dw:ml_is_active , dw:ml_is_hidden , dw:ml_is_moira_mailing_list ,
        dw:ml_is_moira_group , dw:ml_is_nfs_group , dw:ml_is_public ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/moira_list" ;
    mnf:rowCountSnapshot 100000 ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:hasKnownDeficiency
        dw:deficiency_moira_duplicates ,
        dw:deficiency_moira_no_op_filters .

dw:ml_key a mnf:Column ;
    mnf:columnName "MOIRA_LIST_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "PK-ish but duplicated. Equal to MOIRA_LIST_NAME in every row." .

dw:ml_name a mnf:Column ;
    mnf:columnName "MOIRA_LIST_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Anonymised hyphenated word triples ('cat-duo-users', 'amber-amber-emerald'). Always = MOIRA_LIST_KEY." .

dw:ml_description a mnf:Column ;
    mnf:columnName "MOIRA_LIST_DESCRIPTION" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "ALWAYS NULL in this dump." .

dw:ml_is_active a mnf:Column ;
    mnf:columnName "IS_ACTIVE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:YNFlag ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-13] Constant 'Y' — filter is no-op." ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "Y"
    ] .

dw:ml_is_hidden a mnf:Column ;
    mnf:columnName "IS_HIDDEN" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:YNFlag ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-13] Constant 'N' — filter is no-op." ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "N"
    ] .

dw:ml_is_moira_mailing_list a mnf:Column ;
    mnf:columnName "IS_MOIRA_MAILING_LIST" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:YNFlag ;
    mnf:nullable true ;
    rdfs:comment "87,738 'Y' / 12,262 'N'." .

dw:ml_is_moira_group a mnf:Column ;
    mnf:columnName "IS_MOIRA_GROUP" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:YNFlag ;
    mnf:nullable true .

dw:ml_is_nfs_group a mnf:Column ;
    mnf:columnName "IS_NFS_GROUP" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:YNFlag ;
    mnf:nullable true .

dw:ml_is_public a mnf:Column ;
    mnf:columnName "IS_PUBLIC" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:YNFlag ;
    mnf:nullable true .


dw:moira_list_detail a mnf:Dataset ;
    rdfs:label "dw.moira_list_detail — list memberships (one (list, member) per row)" ;
    rdfs:comment """Half of all rows are non-person members (NULL MIT_ID +
        NULL FULL_NAME). 8,023 list keys appear here but NOT in moira_list
        (orphan memberships). MEMBER_MIT_ID is Namespace A.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:mld_list_key , dw:mld_owner_key , dw:mld_member ,
        dw:mld_member_full_name , dw:mld_member_mit_id ,
        dw:mld_last_update_date ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/moira_list_detail" ;
    mnf:rowCountSnapshot 100000 ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:hasKnownDeficiency dw:deficiency_moira_orphan_memberships .

dw:mld_list_key a mnf:Column ;
    mnf:columnName "MOIRA_LIST_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to moira_list.MOIRA_LIST_KEY." .

dw:mld_owner_key a mnf:Column ;
    mnf:columnName "MOIRA_LIST_OWNER_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "FK to moira_list_owner. Per-row, not per-list." .

dw:mld_member a mnf:Column ;
    mnf:columnName "MOIRA_LIST_MEMBER" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:KrbName ;
    mnf:caseConvention mnf:LowerCase ;
    mnf:nullable true ;
    rdfs:comment "Lowercase krb name OR external email OR nested list. Use UPPER() to join to person_auth_area." .

dw:mld_member_full_name a mnf:Column ;
    mnf:columnName "MOIRA_LIST_MEMBER_FULL_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Format 'LastName, FirstName' for people. NULL for non-people." .

dw:mld_member_mit_id a mnf:Column ;
    mnf:columnName "MOIRA_LIST_MEMBER_MIT_ID" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:MITID_NamespaceA ;
    mnf:nullable true ;
    rdfs:comment "9-digit Namespace A MIT_ID. NULL for non-people." .

dw:mld_last_update_date a mnf:Column ;
    mnf:columnName "LAST_UPDATE_DATE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:OracleDateString ;
    mnf:nullable true .


dw:moira_list_owner a mnf:Dataset ;
    rdfs:label "dw.moira_list_owner — owner identity catalogue (NOT keyed by list)" ;
    rdfs:comment """[BVT-K-GAP-1 / BVT-K-GAP-29] Snapshot row count: 46,427.
        PK = OWNER_TYPE + owner-name CONCATENATED (no delimiter):
        'LIST56.928-tangerine-snake', 'USER74.097-...', 'KERBEROSorange-quokka',
        'NONENONE'. dw/118 references one such literal exactly.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:mlo_key ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn dw:mlo_key , dw:mlo_owner , dw:mlo_owner_type ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/moira_list_owner" ;
    mnf:rowCountSnapshot 46427 ;
    mnf:hasProvenance dw:dw_provenance .

dw:mlo_key a mnf:Column ;
    mnf:columnName "MOIRA_LIST_OWNER_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-29] Concatenated <OWNER_TYPE><owner-name>, no delimiter. Splitting requires greedy match against {LIST, USER, KERBEROS, NONE}." .

dw:mlo_owner a mnf:Column ;
    mnf:columnName "OWNER" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "The owner-name part alone (KEY suffix)." .

dw:mlo_owner_type a mnf:Column ;
    mnf:columnName "OWNER_TYPE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:OwnerType ;
    mnf:nullable true ;
    rdfs:comment "LIST=33047 USER=13337 KERBEROS=42 NONE=1." .


