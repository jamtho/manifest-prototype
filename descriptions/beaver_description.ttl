dw:sis_admin_department a mnf:Dataset ;
    rdfs:label "dw.sis_admin_department — admin-office catalogue" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 179. Distinct from
        sis_department; covers admin offices (ADM Admissions, BUR
