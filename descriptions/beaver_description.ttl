    mnf:columnName "D_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:DLCKey ;
    mnf:nullable false .

dw:mddp_d_name a mnf:Column ;
    mnf:columnName "D_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:mddp_parent_id a mnf:Column ;
    mnf:columnName "PARENT_ID" ;
