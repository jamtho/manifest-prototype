dw:tday_day_of_week a mnf:Column ;
    mnf:columnName "DAY_OF_WEEK" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment """[BVT-K-GAP-20] CHAR(9), space-padded right. 'Friday   '
        not 'Friday'. WHERE DAY_OF_WEEK = 'Friday' returns 0 rows; use
        RTRIM, LIKE, or the literal padded form.""" .

dw:tday_academic_term_code a mnf:Column ;
    mnf:columnName "ACADEMIC_TERM_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:TermCode ;
    mnf:nullable true ;
    rdfs:comment "NULL for days between terms." .


