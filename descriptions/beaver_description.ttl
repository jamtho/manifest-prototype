dw:academic_terms_all a mnf:Dataset ;
    rdfs:label "dw.academic_terms_all — canonical term catalogue (300 rows, 1951-2030)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 300. One row per
        (year, season). Date columns are Oracle
        DD-MON-YY strings.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:ata_term_code ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:ata_term_code , dw:ata_term_description , dw:ata_term_selector ,
        dw:ata_academic_year , dw:ata_term_start_date , dw:ata_term_end_date ,
        dw:ata_first_day_of_classes , dw:ata_last_day_of_classes ,
        dw:ata_is_current_term , dw:ata_term_status_indicator ,
        dw:ata_financial_aid_year ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/academic_terms_all" ;
    mnf:rowCountSnapshot 300 ;
    mnf:hasProvenance dw:dw_provenance .

dw:ata_term_code a mnf:Column ;
    mnf:columnName "TERM_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:TermCode ;
    mnf:nullable false .

dw:ata_term_description a mnf:Column ;
    mnf:columnName "TERM_DESCRIPTION" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Inconsistent format: Spring/Fall/Jan use 'Spring Term YYYY-YYYY' (year pair); Summer uses 'Summer Term YYYY' (single year)." .

dw:ata_term_selector a mnf:Column ;
    mnf:columnName "TERM_SELECTOR" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "= TERM_CODE + '-' + TERM_DESCRIPTION." .

dw:ata_academic_year a mnf:Column ;
    mnf:columnName "ACADEMIC_YEAR" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "4-digit string. The spring half of the academic year." .

dw:ata_term_start_date a mnf:Column ;
    mnf:columnName "TERM_START_DATE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:OracleDateString ;
    mnf:nullable true .

dw:ata_term_end_date a mnf:Column ;
    mnf:columnName "TERM_END_DATE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:OracleDateString ;
    mnf:nullable true .

dw:ata_first_day_of_classes a mnf:Column ;
    mnf:columnName "FIRST_DAY_OF_CLASSES" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:OracleDateString ;
    mnf:nullable true .

dw:ata_last_day_of_classes a mnf:Column ;
    mnf:columnName "LAST_DAY_OF_CLASSES" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:OracleDateString ;
    mnf:nullable true .

dw:ata_is_current_term a mnf:Column ;
    mnf:columnName "IS_CURRENT_TERM" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:YNFlag ;
    mnf:nullable true .

dw:ata_term_status_indicator a mnf:Column ;
    mnf:columnName "TERM_STATUS_INDICATOR" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "P" ;
        mnf:allowedValue "C" ;
        mnf:allowedValue "F"
    ] ;
