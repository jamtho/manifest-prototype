dw:iap_subject_detail a mnf:Dataset ;
    rdfs:label "dw.iap_subject_detail — IAP activity registry (2021JA snapshot only)" ;
    rdfs:comment """[BVT-K-GAP-1 / BVT-K-GAP-24] Snapshot row count: 465.
        Central IAP table. ALL 465 rows have TERM_CODE='2021JA' — the
        whole table is a single-term snapshot. 105 distinct
        ACTIVITY_TITLE values; ~4.4 detail rows per activity (one per
        (activity, category) pair). Use SELECT DISTINCT
        ACTIVITY_TITLE.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:isd_activity_title , dw:isd_activity_description ,
        dw:isd_term_code , dw:isd_enrollment_type , dw:isd_max_enrollment ,
        dw:isd_attendance , dw:isd_prerequisites , dw:isd_fee ,
        dw:isd_is_cancelled , dw:isd_is_multiple_session ,
        dw:isd_category_key , dw:isd_sponsor_key ,
        dw:isd_session_key , dw:isd_person_key ,
        dw:isd_create_date , dw:isd_last_activity_date ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/iap_subject_detail" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 465 ;
    mnf:hasKnownDeficiency dw:deficiency_iap_single_term .

