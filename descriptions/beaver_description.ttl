# --- SameEntity declarations ---

dw:dlc_key_identity a mnf:SameEntity ;
    rdfs:label "DLC_KEY identifies the same DLC across all dw tables" ;
    rdfs:comment "Real, non-anonymised DLC keys (D_HISTORY etc.) appear identically across the org/HR/facilities tables." ;
    mnf:identifyingColumn dw:mdh_dlc_key ;
    mnf:identifyingColumn dw:mdh_dlc_code ;
    mnf:identifyingColumn dw:mdhl_dlc_key ;
    mnf:identifyingColumn dw:mddp_d_code ;
    mnf:identifyingColumn dw:sd_dlc_key ;
    mnf:identifyingColumn dw:fo_dlc_key ;
    mnf:identifyingColumn dw:fao_d_code ;
    mnf:identifyingColumn dw:fodk_dlc_key ;
    mnf:identifyingColumn dw:hou_dlc_key ;
    mnf:identifyingColumn dw:houn_dlc_key ;
    mnf:identifyingColumn dw:rfp_dlc_key ;
    mnf:identifyingColumn dw:spu_dlc_key ;
    mnf:identifyingColumn dw:spu2_dlc_key .

dw:term_code_identity a mnf:SameEntity ;
    rdfs:label "TERM_CODE identifies the same academic term across dw tables" ;
