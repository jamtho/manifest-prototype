@prefix mnf:   <http://example.org/manifest#> .
@prefix bvtk:  <http://example.org/beaver-testing/knowledge#> .
@prefix ks:    <http://example.org/beaver-testing/keystone#> .
@prefix dw:    <http://example.org/beaver-testing/dw#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Manifest Description — keystone + dw MySQL databases
# =============================================================================
#
# Structural description of two MySQL databases sourced from MIT's
# infrastructure dumps (released as part of the BEAVER text-to-SQL benchmark,
# Chen et al., 2024, arXiv 2409.02038):
#
#   keystone — OpenStack identity service (CSAIL Stata's deployment).
#               Heavily anonymised; some FKs declared in DDL, others soft.
#               17 populated tables + 4 schema-only (federation tables, all
#               empty in this dump).
#
#   dw       — MIT institutional data warehouse. Real (non-anonymised)
#               campus data; NO FKs declared upstream — all relationships
#               are soft. 97 tables total. This file contains rich
#               descriptions for the most structurally interesting tables
#               (people, subjects, departments, library, IAP, moira, time,
#               facilities) and bare schema stubs for the remaining lookup /
#               history / mirror tables. See the "Schema stubs" section
#               near the end of this file for the stub set.
#
# Intended use: this description (alongside `mnf_core.ttl`) makes the
# data's structural shape — column meanings, anonymisation namespaces,
# soft FKs, sentinel values, case conventions, parallel-table conventions
# — explicit and machine-readable for any consumer that wants to write
# correct SQL against these databases. The description is general-purpose;
# it does NOT carry information about any particular benchmark question
# set, query selection, or model evaluation.
#
# Source materials. Distilled from `beaver-testing/knowledge/{keystone,dw}/`
# — investigations against the live MySQL dumps that established each
# structural fact (anonymisation patterns, sentinels, soft FKs, parallel
# tables, etc.). The investigations themselves are out of scope here; this
# file carries only the structural conclusions.
#
# Coverage of other databases. The BEAVER release also includes `nw` and
# four `csail_stata_*` databases. Those have not yet been investigated;
# they are not described here. They can be added as their own description
# files (or appended) when investigations land.
#
# `[BVT-K-GAP-X]` tags. Inline tags identify places where modelling hit a
# limit of the current `mnf_core` vocabulary and used a workaround. Five
# of the original gaps were resolved in vocabulary round 1
# (see `docs/vocabulary-evolution.md`); the remaining tags refer to gaps
# documented there. Tags persist as historical annotations even where the
# gap has been resolved, since they explain why a particular shape was
# chosen.
# =============================================================================


# =============================================================================
# =============================================================================
# PART 0: Vocabulary evolution
# =============================================================================
#
# This description was modelled against `mnf_core.ttl` v1, then drove a round
# of vocabulary additions when several patterns hit core's expressiveness
# limits. Round 1 (2026-05) added five additive properties / individuals to
# the core vocabulary; the description below uses them throughout.
#
#   GAP-A   — `mnf:JSON`, `mnf:JSONL`, `mnf:NDJSON`, `mnf:PlainText`,
#             `mnf:MySQLTable`, `mnf:PostgreSQLTable`, `mnf:SQLiteTable`
#             added to `FileFormat`. Removed the local placeholder.
#   GAP-1/2 — `mnf:rowCountSnapshot` (xsd:integer) on Dataset. Empty
#             tables collapse to `mnf:rowCountSnapshot 0`.
#   GAP-4   — `mnf:declared` (xsd:boolean) on ForeignKey. Soft FKs are
#             annotated `mnf:declared false`; absence defaults to `true`.
#   GAP-22  — `mnf:identifierNamespace` (xsd:string) on SemanticType.
#             Disjoint identifier populations (e.g. the MIT_ID Namespace
#             A vs B split) become machine-detectable.
#   GAP-25  — `mnf:caseConvention` on Column + `mnf:UpperCase` /
#             `mnf:LowerCase` / `mnf:MixedCase` individuals. Join-key
#             casing differences become explicit.
#
# Inline `[BVT-K-GAP-N]` tags below mark places where modelling either uses
# one of these new terms (resolved gaps) or still uses a workaround for an
# unresolved gap. The full numbered list of gaps surfaced during modelling,
# their motivating examples, and the rationale for each resolution lives in
# `docs/vocabulary-evolution.md`. That doc is the authoritative reference;
# this section is just a pointer.
#
# Notable unresolved gaps that affect this description:
#
#   GAP-3  Polymorphic FKs (e.g. keystone.assignment.actor_id discriminated
#          by .type). Worked around as multiple ForeignKey declarations.
#   GAP-5  Sentinel-string-as-NULL (e.g. `'<<null>>'` in keystone.role).
#          Captured via AllowedValues + commentary; no structural marker.
#   GAP-19 Database-level metadata (cluster taxonomy, prefix legend).
#          Captured as a synthetic `dw:DatabaseCatalogue` Dataset.
#   GAP-L  Generic semantic types redeclared per domain (UUIDHex32,
#          Sha256Hex, etc.). Lives in the local `bvtk:` namespace until
#          a shared `mnf_common.ttl` lands.
#
# These remain workarounds; future rounds may address them.
# =============================================================================
# PART 1: Cross-Cutting Semantic Types
# =============================================================================

bvtk:MySQLIdentifier a mnf:SemanticType ;
    rdfs:label "MySQL Identifier (table or column name)" ;
    rdfs:comment "Bare unquoted identifier as it appears in MySQL DDL." ;
    mnf:requiredPhysicalType mnf:Varchar .

bvtk:UUIDHex32 a mnf:SemanticType ;
    rdfs:label "UUID-without-dashes (32-char lowercase hex)" ;
    rdfs:comment """Keystone's universal id shape. All `id` columns in
        keystone are stored as varchar(64) but values are uniformly 32
        lowercase hex characters. NB: a few sentinel ids break this
        convention (see [BVT-K-GAP-5])." """ ;
    mnf:requiredPhysicalType mnf:Varchar .

bvtk:Sha256Hex a mnf:SemanticType ;
    rdfs:label "SHA-256 Hex (64 lowercase chars)" ;
    rdfs:comment """[BVT-K-GAP-L] Same shape as bvt:Sha256Hex from
        bvt_description.ttl — used here for keystone.credential.id, which
        is uniquely shaped this way (every other id column is 32 hex).""" ;
    mnf:requiredPhysicalType mnf:Varchar .

bvtk:JSONInString a mnf:SemanticType ;
    rdfs:label "JSON encoded as Varchar" ;
    rdfs:comment """Open-shape JSON stored in a string column. Used by
        `extra` columns across keystone (`user.extra`, `trust.extra`,
        `service.extra`, etc.) and `credential.blob`.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

bvtk:USDateString a mnf:SemanticType ;
    rdfs:label "Date as US-format string (MM/DD/YYYY)" ;
    rdfs:comment """[BVT-K-GAP-10] Date stored as varchar in
        `MM/DD/YYYY` format. Examples in dw: DATE_BUILT='07/01/1913',
        DATE_OCCUPIED='12/31/1916'. A query that compares this to a
        real date will silently return wrong results.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

bvtk:OracleShortDateString a mnf:SemanticType ;
    rdfs:label "Date as Oracle short string (DD-MON-YY)" ;
    rdfs:comment """[BVT-K-GAP-10] Date stored as varchar in
        `DD-MON-YY` format. Example in dw: WAREHOUSE_LOAD_DATE='19-DEC-24'.
        2-digit year — ambiguous past 2049.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

bvtk:MySQLBoolean a mnf:SemanticType ;
    rdfs:label "MySQL tinyint(1) used as boolean" ;
    rdfs:comment "0 = false, 1 = true. Stored as `tinyint(1)`." ;
    mnf:requiredPhysicalType mnf:Integer ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "0" ;
        mnf:allowedValue "1"
    ] .


# =============================================================================
# PART 2: Keystone Database
# =============================================================================
#
# OpenStack identity service — users, groups, roles, projects, domains,
# assignments, trusts. Sourced from CSAIL Stata Center's OpenStack
# instance. **Heavily anonymised**: names, passwords, emails, descriptions
# are all replaced. Schema is preserved.
# =============================================================================

# -----------------------------------------------------------------------------
# 2a. Keystone domain semantic types
# -----------------------------------------------------------------------------

ks:UserId a mnf:SemanticType ;
    rdfs:label "Keystone User ID" ;
    rdfs:comment "32-char lowercase hex UUID, primary key of `user`." ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:LocalUserSurrogateId a mnf:SemanticType ;
    rdfs:label "Local-User Surrogate ID" ;
    rdfs:comment """Auto-increment integer PK of `local_user`. NB: this
        is NOT the same as ks:UserId. The chain is:
          user.id (varchar, hex)  →  local_user.user_id  (varchar, hex, FK)
          local_user.id (int) ←  password.local_user_id (int, FK)
        Joining password directly to user.id will fail.""" ;
    mnf:requiredPhysicalType mnf:Integer .

ks:DomainId a mnf:SemanticType ;
    rdfs:label "Keystone Domain ID" ;
    rdfs:comment """Either a 32-char hex UUID, the literal 'default'
        sentinel, or '<<keystone.domain.root>>'. See [BVT-K-GAP-5].""" ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:GroupId a mnf:SemanticType ;
    rdfs:label "Keystone Group ID" ;
    rdfs:comment "32-char hex UUID, PK of `group` (note: reserved word — see [BVT-K-GAP-7])." ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:ProjectId a mnf:SemanticType ;
    rdfs:label "Keystone Project ID" ;
    rdfs:comment """32-char hex UUID, plus 3 sentinel rows: 'default',
        '<<keystone.domain.root>>', and one per Heat domain. See
        ks:domain_project_duality for the cross-table identity.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:RoleId a mnf:SemanticType ;
    rdfs:label "Keystone Role ID" ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:AssignmentType a mnf:SemanticType ;
    rdfs:label "Assignment Polymorphic Type" ;
    rdfs:comment """Discriminator for the polymorphic FKs in
        `assignment(actor_id, target_id)`. Determines which target table
        actor_id and target_id reference. See ks:fk_assignment_*.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "UserProject" ;
        mnf:allowedValue "GroupProject" ;
        mnf:allowedValue "UserDomain" ;
        mnf:allowedValue "GroupDomain"
    ] .

ks:AnonymisedName a mnf:SemanticType ;
    rdfs:label "Anonymised Name (synthetic word-pair)" ;
    rdfs:comment """Synthetic name pattern `word_word.numword` (e.g.
        `prime_helix.306sonic`, `blaze_orbit_glyph`). Used by
        local_user.name, role.name, project.name, group.name.
        Length cluster 17–22 chars.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:AnonymisedEmail a mnf:SemanticType ;
    rdfs:label "Anonymised Email" ;
    rdfs:comment """Pattern `emailvalue.<user.id>` — the email field in
        every user.extra has been replaced by this literal. NOT a real
        RFC822 address.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:AnonymisedPassword a mnf:SemanticType ;
    rdfs:label "Anonymised Password" ;
    rdfs:comment """Pattern `replaced_password.<n>` where n is
        local_user_id. NOT a hash, NOT a real credential — anonymisation
        artefact only.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:AnonymisedAccessKey a mnf:SemanticType ;
    rdfs:label "Anonymised EC2 Access Key" ;
    rdfs:comment "Pattern `accessvalue.<credential.id>` inside credential.blob JSON." ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:AnonymisedSecretKey a mnf:SemanticType ;
    rdfs:label "Anonymised EC2 Secret Key" ;
    rdfs:comment "Pattern `secretvalue.<credential.id>` inside credential.blob JSON." ;
    mnf:requiredPhysicalType mnf:Varchar .

ks:CredentialType a mnf:SemanticType ;
    rdfs:label "Credential Type" ;
    rdfs:comment """In this dump, only 'ec2' appears. Other keystone
        deployments may use 'cert', 'totp', 'application_credential'.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        rdfs:comment "Only 'ec2' is observed in this dump; others are valid keystone values." ;
        mnf:allowedValue "ec2" ;
        mnf:allowedValue "cert" ;
        mnf:allowedValue "totp" ;
        mnf:allowedValue "application_credential"
    ] .

ks:ServiceType a mnf:SemanticType ;
    rdfs:label "OpenStack Service Type" ;
    rdfs:comment """Real-name OpenStack service type (NOT anonymised) —
        the canonical lookup key clients use. Set is closed by OpenStack
        convention.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        rdfs:comment "Values observed in this dump's keystone.service table." ;
        mnf:allowedValue "identity" ;
        mnf:allowedValue "identityv3" ;
        mnf:allowedValue "compute" ;
        mnf:allowedValue "computev3" ;
        mnf:allowedValue "network" ;
        mnf:allowedValue "volume" ;
        mnf:allowedValue "volumev2" ;
        mnf:allowedValue "volumev3" ;
        mnf:allowedValue "image" ;
        mnf:allowedValue "orchestration" ;
        mnf:allowedValue "cloudformation" ;
        mnf:allowedValue "object-store" ;
        mnf:allowedValue "ec2" ;
        mnf:allowedValue "data_processing" ;
        mnf:allowedValue "product-streams"
    ] .

ks:EndpointInterface a mnf:SemanticType ;
    rdfs:label "Endpoint Interface Tier" ;
    rdfs:comment "Three-tier visibility: public/internal/admin." ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "public" ;
        mnf:allowedValue "internal" ;
        mnf:allowedValue "admin"
    ] .

ks:RegionId a mnf:SemanticType ;
    rdfs:label "Keystone Region ID (NOT a UUID)" ;
    rdfs:comment """`region.id` is the human-readable name itself, not
        a generated id. Closed set in this dump: 'CSAIL_Stata',
        'MOC_Kaizen'.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "CSAIL_Stata" ;
        mnf:allowedValue "MOC_Kaizen"
    ] .


# -----------------------------------------------------------------------------
# 2b. Keystone populated tables
# -----------------------------------------------------------------------------

# --- ks:user ----------------------------------------------------------------

ks:user a mnf:Dataset ;
    rdfs:label "keystone.user — abstract user identity" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 944. The
        abstract user identity. Specialised by local_user (1:1) or
        federated_user (empty in this dump). NB: NO `name` column —
        names live in local_user.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:user_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:user_id , ks:user_extra , ks:user_enabled , ks:user_default_project_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/user" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 944 ;
    mnf:hasKnownDeficiency ks:deficiency_default_project_orphans .

ks:user_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:UserId ;
    mnf:nullable false ;
    rdfs:comment "varchar(64) PK; values are 32-char lowercase hex." .

ks:user_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true ;
    rdfs:comment """Uniformly shaped `{"email":"emailvalue.<user.id>",
        "tenantId":null}` for every row in this dump.""" ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "{email: AnonymisedEmail, tenantId: null}"
    ] .

ks:user_enabled a mnf:Column ;
    mnf:columnName "enabled" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-1] 940 enabled, 4 disabled in this dump. Disabled users still have local_user + password rows." .

ks:user_default_project_id a mnf:Column ;
    mnf:columnName "default_project_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:ProjectId ;
    mnf:nullable true ;
    rdfs:comment """[BVT-K-GAP-4] Soft FK — looks like ks:ProjectId but
        0 of 940 non-null values resolve to a real project.id. See
        ks:deficiency_default_project_orphans.""" .


# --- ks:local_user ----------------------------------------------------------

ks:local_user a mnf:Dataset ;
    rdfs:label "keystone.local_user — local-identity specialisation" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 944, strict 1:1
        with user. Names live here. The `id` column is a surrogate
        auto-increment int — references from elsewhere use either
        `user_id` (varchar, the FK back to user) OR `id` (int, FK target
        for password.local_user_id).""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:local_user_pk_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:local_user_pk_id , ks:local_user_user_id ,
        ks:local_user_domain_id , ks:local_user_name ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/local_user" ;
    mnf:rowCountSnapshot 944 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:local_user_pk_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType ks:LocalUserSurrogateId ;
    mnf:nullable false ;
    rdfs:comment "Surrogate auto-increment PK; FK target for password.local_user_id." .

ks:local_user_user_id a mnf:Column ;
    mnf:columnName "user_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:UserId ;
    mnf:nullable false ;
    rdfs:comment "UNIQUE — at most one local_user per user. FK to user.id." .

ks:local_user_domain_id a mnf:Column ;
    mnf:columnName "domain_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:DomainId ;
    mnf:nullable false ;
    rdfs:comment """[BVT-K-GAP-13] Almost-constant: 'default' for 943 of
        944 rows; one user is in domain 'a5df428f538d41e5964e53887aa5e76e'
        (the heat domain). Gold name-lookup queries always filter
        `domain_id='default'` to disambiguate.""" .

ks:local_user_name a mnf:Column ;
    mnf:columnName "name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:AnonymisedName ;
    mnf:nullable false ;
    rdfs:comment "User-facing name; anonymised. UNIQUE within (domain_id, name)." .


# --- ks:federated_user (EMPTY in this dump) ---------------------------------

ks:federated_user a mnf:Dataset ;
    rdfs:label "keystone.federated_user — federated-identity specialisation (EMPTY)" ;
    rdfs:comment """Schema-present but row-empty in this dump. Federation
        is not configured in this deployment, so no users are federated.
        SQL against this table parses and runs but returns no rows.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:federated_user_pk_id , ks:federated_user_user_id ,
        ks:federated_user_idp_id , ks:federated_user_protocol_id ,
        ks:federated_user_unique_id , ks:federated_user_display_name ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/federated_user" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 0 ;
    mnf:hasKnownDeficiency ks:deficiency_empty_federation .

ks:federated_user_pk_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Integer ;
    mnf:nullable false ;
    rdfs:comment "Auto-increment PK." .

ks:federated_user_user_id a mnf:Column ;
    mnf:columnName "user_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:UserId ;
    mnf:nullable false ;
    rdfs:comment "FK to user.id." .

ks:federated_user_idp_id a mnf:Column ;
    mnf:columnName "idp_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "FK to identity_provider.id (empty table)." .

ks:federated_user_protocol_id a mnf:Column ;
    mnf:columnName "protocol_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .

ks:federated_user_unique_id a mnf:Column ;
    mnf:columnName "unique_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .

ks:federated_user_display_name a mnf:Column ;
    mnf:columnName "display_name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .


# --- ks:password ------------------------------------------------------------

ks:password a mnf:Dataset ;
    rdfs:label "keystone.password — credentials (heavily anonymised)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 944, strict 1:1
        with local_user. Older keystone schema — only 3 columns. Modern
        deployments would have password_hash, expires_at, self_service —
        they're absent here.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:password_pk_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:password_pk_id , ks:password_local_user_id , ks:password_password ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/password" ;
    mnf:rowCountSnapshot 944 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:password_pk_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Integer ;
    mnf:nullable false ;
    rdfs:comment "Auto-increment surrogate PK." .

ks:password_local_user_id a mnf:Column ;
    mnf:columnName "local_user_id" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType ks:LocalUserSurrogateId ;
    mnf:nullable false ;
    rdfs:comment "FK to local_user.id (the int surrogate, NOT user_id)." .

ks:password_password a mnf:Column ;
    mnf:columnName "password" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:AnonymisedPassword ;
    mnf:nullable true ;
    rdfs:comment "Anonymised to `replaced_password.<n>`. NOT a hash." .


# --- ks:group (RESERVED WORD) ----------------------------------------------

ks:group a mnf:Dataset ;
    rdfs:label "keystone.group — identity groups (MySQL RESERVED WORD)" ;
    rdfs:comment """Single group named `proto4` in this dump.

        `group` is a MySQL reserved word — every reference in SQL must be
        backticked (`` `group` ``) or the parser will error.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:group_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:group_id , ks:group_domain_id , ks:group_name ,
        ks:group_description , ks:group_extra ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/group" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 1 ;
    mnf:hasKnownDeficiency ks:deficiency_group_reserved_word .

ks:group_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:GroupId ;
    mnf:nullable false .

ks:group_domain_id a mnf:Column ;
    mnf:columnName "domain_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:DomainId ;
    mnf:nullable false .

ks:group_name a mnf:Column ;
    mnf:columnName "name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:AnonymisedName ;
    mnf:nullable false ;
    rdfs:comment "UNIQUE within (domain_id, name)." .

ks:group_description a mnf:Column ;
    mnf:columnName "description" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "NULL for the only row in this dump." .

ks:group_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true ;
    rdfs:comment "`{}` for the only row in this dump." .


# --- ks:user_group_membership ----------------------------------------------

ks:user_group_membership a mnf:Dataset ;
    rdfs:label "keystone.user_group_membership — group memberships" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 10, all to the
        single `proto4` group. Both columns are declared FKs.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:ugm_user_id , ks:ugm_group_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/user_group_membership" ;
    mnf:rowCountSnapshot 10 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:ugm_user_id a mnf:Column ;
    mnf:columnName "user_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:UserId ;
    mnf:nullable false ;
    rdfs:comment "FK to user.id, declared and enforced. Composite PK with group_id." .

ks:ugm_group_id a mnf:Column ;
    mnf:columnName "group_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:GroupId ;
    mnf:nullable false ;
    rdfs:comment "FK to group.id, declared and enforced." .


# --- ks:project -------------------------------------------------------------

ks:project a mnf:Dataset ;
    rdfs:label "keystone.project — tenants (and domains, see duality)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 923. Self-
        referential: `domain_id` and `parent_id` both FK back to
        `project.id`. 3 rows have `is_domain=1` and parent_id=NULL —
        these are the domain-as-project rows. See
        ks:domain_project_duality.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:project_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:project_id , ks:project_name , ks:project_extra ,
        ks:project_description , ks:project_enabled ,
        ks:project_domain_id , ks:project_parent_id , ks:project_is_domain ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/project" ;
    mnf:rowCountSnapshot 923 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:project_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:ProjectId ;
    mnf:nullable false ;
    rdfs:comment "32-char hex UUID OR sentinel ('default', '<<keystone.domain.root>>'). [BVT-K-GAP-5]" .

ks:project_name a mnf:Column ;
    mnf:columnName "name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:AnonymisedName ;
    mnf:nullable false .

ks:project_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true .

ks:project_description a mnf:Column ;
    mnf:columnName "description" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Anonymised but populated." .

ks:project_enabled a mnf:Column ;
    mnf:columnName "enabled" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable true .

ks:project_domain_id a mnf:Column ;
    mnf:columnName "domain_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:ProjectId ;
    mnf:nullable false ;
    rdfs:comment """FK to project.id (NOT to domain.id). The 'domain' a
        project belongs to is referenced as the project-version of that
        domain.""" .

ks:project_parent_id a mnf:Column ;
    mnf:columnName "parent_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:ProjectId ;
    mnf:nullable true ;
    rdfs:comment """Self-referential FK. NULL only for the 3 is_domain
        rows + 3 ordinary projects with no parent (genuine roots).""" .

ks:project_is_domain a mnf:Column ;
    mnf:columnName "is_domain" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable false ;
    rdfs:comment "1 for the 3 domain-as-project rows; 0 for the other 920." .


# --- ks:domain --------------------------------------------------------------

ks:domain a mnf:Dataset ;
    rdfs:label "keystone.domain — top-level identity containers (domain-as-project duality)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 3. Same ids as the
        three `project` rows where `is_domain=1`. The `domain` table
        kept the real names ('Default', 'heat'); the twin project rows
        were anonymised. See ks:domain_project_duality.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:domain_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:domain_id , ks:domain_name , ks:domain_enabled , ks:domain_extra ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/domain" ;
    mnf:rowCountSnapshot 3 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:domain_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:DomainId ;
    mnf:nullable false .

ks:domain_name a mnf:Column ;
    mnf:columnName "name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Real names retained (NOT anonymised) — 'Default', 'heat', '<<keystone.domain.root>>'." .

ks:domain_enabled a mnf:Column ;
    mnf:columnName "enabled" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable false .

ks:domain_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true ;
    rdfs:comment "Carries the original `description` field (real, not anonymised)." .


# --- ks:role ----------------------------------------------------------------

ks:role a mnf:Dataset ;
    rdfs:label "keystone.role — named roles" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 6. UNIQUE on
        (name, domain_id). Names are anonymised except 'xenon' (the
        OpenStack default-member role kept its description JSON, which
        gives away the real role).""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:role_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:role_id , ks:role_name , ks:role_extra , ks:role_domain_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/role" ;
    mnf:rowCountSnapshot 6 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:role_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:RoleId ;
    mnf:nullable false .

ks:role_name a mnf:Column ;
    mnf:columnName "name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:AnonymisedName ;
    mnf:nullable false .

ks:role_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true .

ks:role_domain_id a mnf:Column ;
    mnf:columnName "domain_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment """[BVT-K-GAP-5] Constant '<<null>>' for every row —
        the literal six-character sentinel string meaning 'global, not
        domain-scoped'. NOT a SQL NULL.""" ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "<<null>>"
    ] .


# --- ks:assignment (POLYMORPHIC FK) ----------------------------------------

ks:assignment a mnf:Dataset ;
    rdfs:label "keystone.assignment — authorisation edges (polymorphic)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 3,433 (largest
        keystone table). Polymorphic on `type` — actor_id resolves to
        user.id (when type LIKE 'User%') or group.id (when type LIKE
        'Group%'); target_id resolves to project.id or domain.id.
        99.5% are UserProject; 1 UserDomain, 0 GroupDomain. See
        [BVT-K-GAP-3].""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:assignment_type , ks:assignment_actor_id ,
        ks:assignment_target_id , ks:assignment_role_id ,
        ks:assignment_inherited ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/assignment" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 3433 ;
    mnf:hasKnownDeficiency ks:deficiency_assignment_polymorphic .

ks:assignment_type a mnf:Column ;
    mnf:columnName "type" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:AssignmentType ;
    mnf:nullable false ;
    rdfs:comment "Discriminator for the polymorphic FKs. Part of composite PK." .

ks:assignment_actor_id a mnf:Column ;
    mnf:columnName "actor_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment """[BVT-K-GAP-3 / BVT-K-GAP-4] Polymorphic soft FK —
        targets user.id or group.id depending on `type`. Verified clean
        (no contamination)." """ .

ks:assignment_target_id a mnf:Column ;
    mnf:columnName "target_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-3 / BVT-K-GAP-4] Polymorphic soft FK — targets project.id or domain.id." .

ks:assignment_role_id a mnf:Column ;
    mnf:columnName "role_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:RoleId ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to role.id — not declared in DDL but every value resolves." .

ks:assignment_inherited a mnf:Column ;
    mnf:columnName "inherited" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable false ;
    rdfs:comment "Constant 0 in this dump — never inherited. Part of composite PK." ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        rdfs:comment "Only 0 is observed." ;
        mnf:allowedValue "0"
    ] .


# --- ks:trust + ks:trust_role -----------------------------------------------

ks:trust a mnf:Dataset ;
    rdfs:label "keystone.trust — time-bounded role delegations" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 82, of which 75
        are soft-deleted (deleted_at NOT NULL). 83% are auto-generated
        by Heat orchestration (extra carries 'heat_stack_owner' as a
        role name not present in role table). All four user/project
        references are soft FKs.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:trust_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:trust_id , ks:trust_trustor_user_id , ks:trust_trustee_user_id ,
        ks:trust_project_id , ks:trust_impersonation , ks:trust_deleted_at ,
        ks:trust_expires_at , ks:trust_extra , ks:trust_remaining_uses ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/trust" ;
    mnf:rowCountSnapshot 82 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:trust_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .

ks:trust_trustor_user_id a mnf:Column ;
    mnf:columnName "trustor_user_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:UserId ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to user.id." .

ks:trust_trustee_user_id a mnf:Column ;
    mnf:columnName "trustee_user_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:UserId ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK. Diversity: only 1 distinct trustee (the Heat service account)." .

ks:trust_project_id a mnf:Column ;
    mnf:columnName "project_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:ProjectId ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK. 11 of 82 references don't resolve (anonymisation gap)." .

ks:trust_impersonation a mnf:Column ;
    mnf:columnName "impersonation" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable true .

ks:trust_deleted_at a mnf:Column ;
    mnf:columnName "deleted_at" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "MySQL DATETIME stored. NULL = live; NOT NULL = soft-deleted (75 of 82 rows)." .

ks:trust_expires_at a mnf:Column ;
    mnf:columnName "expires_at" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "NULL for every row in this dump — no trust ever expires." .

ks:trust_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true ;
    rdfs:comment """Two shapes: `{"roles":[{"name":"heat_stack_owner"}]}`
        (68 rows) and `{"redelegation_count":0,"roles":[{"id":"<role.id>"}, ...]}`
        (14 rows). The first carries a role NAME that has no row in the
        role table — partly redundant with trust_role.""" .

ks:trust_remaining_uses a mnf:Column ;
    mnf:columnName "remaining_uses" ;
    mnf:physicalType mnf:Integer ;
    mnf:nullable true .

ks:trust_role a mnf:Dataset ;
    rdfs:label "keystone.trust_role — roles granted within a trust" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 96. Every trust
        has at least one trust_role row.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:trust_role_trust_id , ks:trust_role_role_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/trust_role" ;
    mnf:rowCountSnapshot 96 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:trust_role_trust_id a mnf:Column ;
    mnf:columnName "trust_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to trust.id." .

ks:trust_role_role_id a mnf:Column ;
    mnf:columnName "role_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:RoleId ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to role.id." .


# --- ks:credential ----------------------------------------------------------

ks:credential a mnf:Dataset ;
    rdfs:label "keystone.credential — additional credentials (EC2 only here)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 144. All rows have
        type='ec2'. PK is 64-char hex (sha256-shaped, NOT 32 like every
        other keystone id). 1 of 144 user_id references is orphan.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:credential_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:credential_id , ks:credential_user_id , ks:credential_project_id ,
        ks:credential_blob , ks:credential_type , ks:credential_extra ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/credential" ;
    mnf:rowCountSnapshot 144 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:credential_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:Sha256Hex ;
    mnf:nullable false ;
    rdfs:comment "varchar(64) holding 64 hex chars — sha256-shaped, unlike other keystone ids." .

ks:credential_user_id a mnf:Column ;
    mnf:columnName "user_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:UserId ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to user.id; 143 of 144 resolve." .

ks:credential_project_id a mnf:Column ;
    mnf:columnName "project_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:ProjectId ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to project.id." .

ks:credential_blob a mnf:Column ;
    mnf:columnName "blob" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable false ;
    rdfs:comment """Uniformly shaped:
        `{"access":"accessvalue.<id>","secret":"secretvalue.<id>","trust_id":null}`.
        Anonymised; trust_id always null.""" ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "{access: AnonymisedAccessKey, secret: AnonymisedSecretKey, trust_id: null}"
    ] .

ks:credential_type a mnf:Column ;
    mnf:columnName "type" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:CredentialType ;
    mnf:nullable false ;
    rdfs:comment "Always 'ec2' in this dump." ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "ec2"
    ] .

ks:credential_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true ;
    rdfs:comment "Always `{}` in this dump." .


# --- ks:region --------------------------------------------------------------

ks:region a mnf:Dataset ;
    rdfs:label "keystone.region — endpoint geographic grouping" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 2. Real names
        retained: 'CSAIL_Stata', 'MOC_Kaizen'. NB: `id` IS the
        human-readable name, not a UUID.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:region_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:region_id , ks:region_description , ks:region_parent_region_id , ks:region_extra ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/region" ;
    mnf:rowCountSnapshot 2 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:region_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:RegionId ;
    mnf:nullable false ;
    rdfs:comment "Human-readable name; NOT a UUID. By design in keystone." .

ks:region_description a mnf:Column ;
    mnf:columnName "description" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "CSAIL_Stata's looks like an anonymised hash; MOC_Kaizen's is empty." .

ks:region_parent_region_id a mnf:Column ;
    mnf:columnName "parent_region_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:RegionId ;
    mnf:nullable true ;
    rdfs:comment "Self-referential. NULL for both rows." .

ks:region_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true .


# --- ks:service + ks:endpoint ----------------------------------------------

ks:service a mnf:Dataset ;
    rdfs:label "keystone.service — OpenStack service catalogue" ;
    rdfs:comment """All 15 services are enabled. Service `type` values
        are real (NOT anonymised) — the canonical lookup key. The set of
        types tells consumers which OpenStack components ran in this
        deployment (nova / neutron / cinder / glance / keystone).""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:service_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:service_id , ks:service_type , ks:service_enabled , ks:service_extra ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/service" ;
    mnf:rowCountSnapshot 15 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:service_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .

ks:service_type a mnf:Column ;
    mnf:columnName "type" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:ServiceType ;
    mnf:nullable false ;
    rdfs:comment "Real values retained — see ks:ServiceType allowed values." .

ks:service_enabled a mnf:Column ;
    mnf:columnName "enabled" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable false ;
    rdfs:comment "Constant 1 in this dump." ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "1"
    ] .

ks:service_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Anonymised opaque hex — the original service name/description JSON was redacted." .


ks:endpoint a mnf:Dataset ;
    rdfs:label "keystone.endpoint — service URL bindings per region" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 46, all enabled.
        Three interfaces (public/internal/admin) per (service, region)
        in the typical pattern.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey ks:endpoint_id ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        ks:endpoint_id , ks:endpoint_legacy_endpoint_id , ks:endpoint_interface ,
        ks:endpoint_service_id , ks:endpoint_url , ks:endpoint_extra ,
        ks:endpoint_enabled , ks:endpoint_region_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/endpoint" ;
    mnf:rowCountSnapshot 46 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:endpoint_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .

ks:endpoint_legacy_endpoint_id a mnf:Column ;
    mnf:columnName "legacy_endpoint_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

ks:endpoint_interface a mnf:Column ;
    mnf:columnName "interface" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:EndpointInterface ;
    mnf:nullable false .

ks:endpoint_service_id a mnf:Column ;
    mnf:columnName "service_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Declared FK to service.id." .

ks:endpoint_url a mnf:Column ;
    mnf:columnName "url" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Anonymised hostnames + paths." .

ks:endpoint_extra a mnf:Column ;
    mnf:columnName "extra" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable true .

ks:endpoint_enabled a mnf:Column ;
    mnf:columnName "enabled" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable false .

ks:endpoint_region_id a mnf:Column ;
    mnf:columnName "region_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ks:RegionId ;
    mnf:nullable false ;
    rdfs:comment "Declared FK to region.id (which is a name, not a UUID)." .


# --- ks:revocation_event ---------------------------------------------------

ks:revocation_event a mnf:Dataset ;
    rdfs:label "keystone.revocation_event — token revocation history" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 1. 13 columns,
        most of which are nullable polymorphic-ish references
        (domain_id, project_id, user_id, role_id, trust_id, consumer_id,
        access_token_id) — a revocation can target any of these. Only
        `id`, `revoked_at`, and `issued_before` are NOT NULL.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:re_id , ks:re_revoked_at , ks:re_audit_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/revocation_event" ;
    mnf:rowCountSnapshot 1 ;
    mnf:hasProvenance ks:keystone_provenance .

ks:re_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Integer ;
    mnf:nullable false ;
    rdfs:comment "Auto-increment PK." .

ks:re_revoked_at a mnf:Column ;
    mnf:columnName "revoked_at" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "MySQL DATETIME." .

ks:re_audit_id a mnf:Column ;
    mnf:columnName "audit_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "varchar(32). Token audit trail identifier." .


# -----------------------------------------------------------------------------
# 2c. Keystone empty-but-schema-present tables (federation cluster)
# -----------------------------------------------------------------------------
# These four tables have real declared schemas but hold zero rows in this
# dump, because federation is not configured in the deployment. SQL
# against them parses and runs but returns no rows. Modelled here so that
# the schema is queryable from the graph.

ks:identity_provider a mnf:Dataset ;
    rdfs:label "keystone.identity_provider — federation IdPs (EMPTY)" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:idp_id , ks:idp_enabled , ks:idp_description ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/identity_provider" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 0 ;
    mnf:hasKnownDeficiency ks:deficiency_empty_federation .

ks:idp_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "varchar(64) PK." .

ks:idp_enabled a mnf:Column ;
    mnf:columnName "enabled" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable false .

ks:idp_description a mnf:Column ;
    mnf:columnName "description" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .


ks:federation_protocol a mnf:Dataset ;
    rdfs:label "keystone.federation_protocol — federation protocols (EMPTY)" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:fp_id , ks:fp_idp_id , ks:fp_mapping_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/federation_protocol" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 0 ;
    mnf:hasKnownDeficiency ks:deficiency_empty_federation .

ks:fp_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .

ks:fp_idp_id a mnf:Column ;
    mnf:columnName "idp_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Declared FK to identity_provider.id." .

ks:fp_mapping_id a mnf:Column ;
    mnf:columnName "mapping_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "Declared FK to mapping.id." .


ks:mapping a mnf:Dataset ;
    rdfs:label "keystone.mapping — federation attribute mapping (EMPTY)" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:mapping_id_col , ks:mapping_rules ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/mapping" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 0 ;
    mnf:hasKnownDeficiency ks:deficiency_empty_federation .

ks:mapping_id_col a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .

ks:mapping_rules a mnf:Column ;
    mnf:columnName "rules" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:JSONInString ;
    mnf:nullable false ;
    rdfs:comment "Stored as `text`, JSON content." .


ks:idp_remote_ids a mnf:Dataset ;
    rdfs:label "keystone.idp_remote_ids — federation remote-id list (EMPTY)" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn ks:iri_idp_id , ks:iri_remote_id ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://keystone/idp_remote_ids" ;
    mnf:hasProvenance ks:keystone_provenance ;
    mnf:rowCountSnapshot 0 ;
    mnf:hasKnownDeficiency ks:deficiency_empty_federation .

ks:iri_idp_id a mnf:Column ;
    mnf:columnName "idp_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "FK to identity_provider.id." .

ks:iri_remote_id a mnf:Column ;
    mnf:columnName "remote_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false .


# -----------------------------------------------------------------------------
# 2d. Keystone — Anonymisation derivations
# -----------------------------------------------------------------------------

ks:derive_anon_email a mnf:Derivation ;
    rdfs:label "Anonymisation: real email → emailvalue.<user.id>" ;
    rdfs:comment "[BVT-K-GAP-9] Replaces real email addresses inside user.extra JSON with a literal." ;
    mnf:derivedColumn ks:user_extra ;
    mnf:derivationFunction bvtk:KeystoneEmailAnonymisation ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Lossy .

ks:derive_anon_password a mnf:Derivation ;
    rdfs:label "Anonymisation: real password → replaced_password.<n>" ;
    mnf:derivedColumn ks:password_password ;
    mnf:sourceColumn ks:password_local_user_id ;
    mnf:derivationFunction bvtk:KeystonePasswordAnonymisation ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Lossy .

ks:derive_anon_local_user_name a mnf:Derivation ;
    rdfs:label "Anonymisation: real name → synthetic word_word.numword" ;
    mnf:derivedColumn ks:local_user_name ;
    mnf:derivationFunction bvtk:KeystoneWordPairAnonymisation ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Lossy .

ks:derive_anon_role_name a mnf:Derivation ;
    rdfs:label "Anonymisation: role.name (except 'xenon')" ;
    mnf:derivedColumn ks:role_name ;
    mnf:derivationFunction bvtk:KeystoneWordPairAnonymisation ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Lossy .

ks:derive_anon_credential_blob a mnf:Derivation ;
    rdfs:label "Anonymisation: credential.blob → access/secret literals" ;
    mnf:derivedColumn ks:credential_blob ;
    mnf:sourceColumn ks:credential_id ;
    mnf:derivationFunction bvtk:KeystoneCredentialAnonymisation ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Lossy .


# Anonymisation function URIs.

bvtk:KeystoneEmailAnonymisation a rdfs:Resource ;
    rdfs:label "user.extra.email := 'emailvalue.' + user.id" .

bvtk:KeystonePasswordAnonymisation a rdfs:Resource ;
    rdfs:label "password.password := 'replaced_password.' + local_user_id" .

bvtk:KeystoneWordPairAnonymisation a rdfs:Resource ;
    rdfs:label "name := word_word.numword (random synthetic)" .

bvtk:KeystoneCredentialAnonymisation a rdfs:Resource ;
    rdfs:label "credential.blob := {access:'accessvalue.'+id, secret:'secretvalue.'+id, trust_id:null}" .


# -----------------------------------------------------------------------------
# 2e. Keystone — Foreign keys (declared and soft)
# -----------------------------------------------------------------------------

# Declared and enforced FKs.

ks:fk_local_user_user a mnf:ForeignKey ;
    rdfs:label "local_user.user_id → user.id (declared, UNIQUE)" ;
    mnf:foreignKeyFrom ks:local_user_user_id ;
    mnf:foreignKeyTo ks:user_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "Declared in DDL, enforced. UNIQUE — at most one local_user per user." .

ks:fk_federated_user_user a mnf:ForeignKey ;
    rdfs:label "federated_user.user_id → user.id (declared)" ;
    mnf:foreignKeyFrom ks:federated_user_user_id ;
    mnf:foreignKeyTo ks:user_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "Declared. Vacuously satisfied here (federated_user is empty)." .

ks:fk_password_local_user a mnf:ForeignKey ;
    rdfs:label "password.local_user_id → local_user.id (declared)" ;
    mnf:foreignKeyFrom ks:password_local_user_id ;
    mnf:foreignKeyTo ks:local_user_pk_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_ugm_user a mnf:ForeignKey ;
    rdfs:label "user_group_membership.user_id → user.id (declared)" ;
    mnf:foreignKeyFrom ks:ugm_user_id ;
    mnf:foreignKeyTo ks:user_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_ugm_group a mnf:ForeignKey ;
    rdfs:label "user_group_membership.group_id → group.id (declared)" ;
    mnf:foreignKeyFrom ks:ugm_group_id ;
    mnf:foreignKeyTo ks:group_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_endpoint_service a mnf:ForeignKey ;
    rdfs:label "endpoint.service_id → service.id (declared)" ;
    mnf:foreignKeyFrom ks:endpoint_service_id ;
    mnf:foreignKeyTo ks:service_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_endpoint_region a mnf:ForeignKey ;
    rdfs:label "endpoint.region_id → region.id (declared)" ;
    mnf:foreignKeyFrom ks:endpoint_region_id ;
    mnf:foreignKeyTo ks:region_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_project_domain a mnf:ForeignKey ;
    rdfs:label "project.domain_id → project.id (self-FK; declared)" ;
    mnf:foreignKeyFrom ks:project_domain_id ;
    mnf:foreignKeyTo ks:project_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "References project.id NOT domain.id — see ks:domain_project_duality." .

ks:fk_project_parent a mnf:ForeignKey ;
    rdfs:label "project.parent_id → project.id (self-FK; declared)" ;
    mnf:foreignKeyFrom ks:project_parent_id ;
    mnf:foreignKeyTo ks:project_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

# Soft (un-declared) FKs.

ks:fk_user_default_project a mnf:ForeignKey ;
    rdfs:label "user.default_project_id → project.id (SOFT, BROKEN)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:user_default_project_id ;
    mnf:foreignKeyTo ks:project_id ;
    mnf:referentialIntegrity mnf:PartialIntegrity ;
    rdfs:comment """[BVT-K-GAP-4] Soft FK — not declared in DDL. Empirically
        BROKEN: 0 of 940 non-null values resolve. Anonymisation artefact.
        See ks:deficiency_default_project_orphans.""" .

ks:fk_assignment_role a mnf:ForeignKey ;
    rdfs:label "assignment.role_id → role.id (SOFT)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:assignment_role_id ;
    mnf:foreignKeyTo ks:role_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK; every value resolves." .

ks:fk_assignment_actor_user a mnf:ForeignKey ;
    rdfs:label "assignment.actor_id → user.id (when type LIKE 'User%') — POLYMORPHIC SOFT" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:assignment_actor_id ;
    mnf:foreignKeyTo ks:user_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "[BVT-K-GAP-3 / BVT-K-GAP-4] Conditional on assignment.type — see ks:assignment_polymorphic." .

ks:fk_assignment_actor_group a mnf:ForeignKey ;
    rdfs:label "assignment.actor_id → group.id (when type LIKE 'Group%') — POLYMORPHIC SOFT" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:assignment_actor_id ;
    mnf:foreignKeyTo ks:group_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "[BVT-K-GAP-3 / BVT-K-GAP-4] Conditional on assignment.type." .

ks:fk_assignment_target_project a mnf:ForeignKey ;
    rdfs:label "assignment.target_id → project.id (when type LIKE '%Project') — POLYMORPHIC SOFT" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:assignment_target_id ;
    mnf:foreignKeyTo ks:project_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_assignment_target_domain a mnf:ForeignKey ;
    rdfs:label "assignment.target_id → domain.id (when type LIKE '%Domain') — POLYMORPHIC SOFT" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:assignment_target_id ;
    mnf:foreignKeyTo ks:domain_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment """[BVT-K-GAP-3] Note: target is `project.id` because
        domains are stored as projects (is_domain=1). The domain.id
        target above happens to coincide because of duality.""" .

ks:fk_credential_user a mnf:ForeignKey ;
    rdfs:label "credential.user_id → user.id (SOFT, partial)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:credential_user_id ;
    mnf:foreignKeyTo ks:user_id ;
    mnf:referentialIntegrity mnf:PartialIntegrity ;
    rdfs:comment "[BVT-K-GAP-4] 143 of 144 resolve; 1 orphan." .

ks:fk_credential_project a mnf:ForeignKey ;
    rdfs:label "credential.project_id → project.id (SOFT)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:credential_project_id ;
    mnf:foreignKeyTo ks:project_id ;
    mnf:referentialIntegrity mnf:PartialIntegrity .

ks:fk_trust_trustor a mnf:ForeignKey ;
    rdfs:label "trust.trustor_user_id → user.id (SOFT)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:trust_trustor_user_id ;
    mnf:foreignKeyTo ks:user_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity ;
    rdfs:comment "[BVT-K-GAP-4] All 82 resolve cleanly." .

ks:fk_trust_trustee a mnf:ForeignKey ;
    rdfs:label "trust.trustee_user_id → user.id (SOFT)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:trust_trustee_user_id ;
    mnf:foreignKeyTo ks:user_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_trust_project a mnf:ForeignKey ;
    rdfs:label "trust.project_id → project.id (SOFT, partial)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:trust_project_id ;
    mnf:foreignKeyTo ks:project_id ;
    mnf:referentialIntegrity mnf:PartialIntegrity ;
    rdfs:comment "[BVT-K-GAP-4] 71 of 82 resolve; 11 orphan (anonymisation gap)." .

ks:fk_trust_role_trust a mnf:ForeignKey ;
    rdfs:label "trust_role.trust_id → trust.id (SOFT)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:trust_role_trust_id ;
    mnf:foreignKeyTo ks:trust_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .

ks:fk_trust_role_role a mnf:ForeignKey ;
    rdfs:label "trust_role.role_id → role.id (SOFT)" ;
    mnf:declared false ;
    mnf:foreignKeyFrom ks:trust_role_role_id ;
    mnf:foreignKeyTo ks:role_id ;
    mnf:referentialIntegrity mnf:StrictIntegrity .


# -----------------------------------------------------------------------------
# 2f. Keystone — Cross-table identity & specialisation
# -----------------------------------------------------------------------------

ks:domain_project_duality a mnf:SameEntity ;
    rdfs:label "Domain identity is also a project (where is_domain=1)" ;
    rdfs:comment """The 3 rows in `domain` share their ids with the 3
        rows in `project` where is_domain=1. The same logical domain
        appears in both tables. domain.name kept the real names;
        project.name was anonymised. Joining on id works.""" ;
    mnf:identifyingColumn ks:domain_id ;
    mnf:identifyingColumn ks:project_id .

ks:user_specialisation a mnf:SameEntity ;
    rdfs:label "user → local_user / federated_user (1:1, mutually exclusive)" ;
    rdfs:comment """[BVT-K-GAP-6] Every user has exactly one of
        local_user OR federated_user. SameEntity captures the join key;
        the mutual-exclusivity constraint has no first-class place in
        the vocab (we model it as a deficiency on federated_user).""" ;
    mnf:identifyingColumn ks:user_id ;
    mnf:identifyingColumn ks:local_user_user_id ;
    mnf:identifyingColumn ks:federated_user_user_id .

ks:assignment_polymorphic a mnf:KnownDeficiency ;
    rdfs:label "Assignment uses polymorphic actor_id/target_id keyed by `type`" ;
    mnf:deficiencyDescription """[BVT-K-GAP-3] `assignment(type, actor_id,
        target_id)` is polymorphic on type:
          UserProject → actor_id ∈ user.id, target_id ∈ project.id
          GroupProject → actor_id ∈ group.id, target_id ∈ project.id
          UserDomain → actor_id ∈ user.id, target_id ∈ domain.id (=project.id by duality)
          GroupDomain → actor_id ∈ group.id, target_id ∈ domain.id (0 rows in this dump)
        mnf:ForeignKey can't express the discriminator-driven target
        cleanly; we declare four ForeignKeys (one per variant) with
        comments. Verified clean in this dump — no contamination.""" ;
    mnf:impact "Joining `assignment.actor_id` to `user.id` without filtering on type LIKE 'User%' picks up no extra rows by accident here, but is conceptually wrong." ;
    mnf:severity mnf:Moderate .


# -----------------------------------------------------------------------------
# 2g. Keystone — Provenance and known deficiencies
# -----------------------------------------------------------------------------

ks:keystone_provenance a mnf:Provenance ;
    mnf:source <https://www.openstack.org/software/releases/> ;
    mnf:sourceDescription """OpenStack identity service (keystone) MySQL
        dump from CSAIL Stata Center. Heavily anonymised: all names,
        passwords, emails, descriptions, hostnames replaced with
        synthetic / literal patterns. Schema preserved; some metadata
        (service.type, region.id, domain.name, role 'xenon' description)
        retained.""" ;
    mnf:hasTransformation [
        a mnf:Transformation ;
        mnf:transformationType "anonymisation" ;
        mnf:transformationDescription """Per-domain anonymisation:
            user names → word_word.numword; emails → emailvalue.<user.id>;
            passwords → replaced_password.<local_user_id>; project names
            → word_word.<random>; role names → word_word (except 'xenon')."""
    ] ;
    mnf:hasTransformation [
        a mnf:Transformation ;
        mnf:transformationType "id_re_randomisation" ;
        mnf:transformationDescription """[BVT-K-GAP-4] Some 32-char hex
            ids were re-generated independently per table, breaking
            cross-table FKs that weren't enforced (notably
            user.default_project_id, trust.project_id partial,
            credential.user_id partial). Declared FKs were preserved."""
    ] .

ks:deficiency_default_project_orphans a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """user.default_project_id is non-null on
        940 of 944 users; ZERO of these resolve to a real project.id.
        Anonymisation re-randomised user-side and project-side ids
        independently.""" ;
    mnf:impact "Joining user→project on default_project_id silently returns no rows. The link is unusable for navigation; use assignment.target_id or trust.project_id instead." ;
    mnf:severity mnf:Severe .

ks:deficiency_empty_federation a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """Federation tables (federated_user,
        identity_provider, federation_protocol, mapping, idp_remote_ids)
        are schema-present but empty in this dump. Federation is not
        configured in this deployment.""" ;
    mnf:impact "Queries against federated_user / identity_provider / federation_protocol / mapping / idp_remote_ids parse and run but return zero rows." ;
    mnf:severity mnf:Moderate .

ks:deficiency_group_reserved_word a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """`group` is a MySQL reserved word. Any
        unquoted reference parses as a syntax error. Must be backticked
        (`` `group` ``) or wrapped in a subquery / aliased.""" ;
    mnf:impact "Direct reference without backticks fails at parse time." ;
    mnf:severity mnf:Severe .


# =============================================================================
# PART 3: DW Database — MIT Institutional Data Warehouse
# =============================================================================
#
# 97 tables, ~9.84M rows. Real institutional data (NOT anonymised).
# Building names ("THE SIMONS BUILDING"), real coordinates, real
# named-for attributions, real dates. Buildings, departments, courses,
# library, IAP, students, employees, terms.
#
# Investigations are partial — high-level overview + facilities cluster
# (buildings, addresses, rooms, floors, space-*) covered. Other clusters
# (subjects, library, MOIRA, IAP, employees) are stubbed or unmodelled.
#
# Critically: NO declared PKs/FKs in upstream/dev_tables.json. Every
# relationship below is a soft FK [BVT-K-GAP-4]. Join knowledge has to
# come from upstream/dw_join_keys.json (1,034 pairs) plus these
# investigations.
# =============================================================================

# -----------------------------------------------------------------------------
# 3a. DW domain semantic types
# -----------------------------------------------------------------------------

dw:BuildingNumber a mnf:SemanticType ;
    rdfs:label "MIT Building Number" ;
    rdfs:comment """Old-school MIT building identifier. Three patterns:
        pure numeric ('1'–'77', main campus core, 45 buildings);
        compass-prefixed ('W32', 'NW17', 'E40', 114 buildings); compass-
        and-suffixed ('W61A', 'W85ABC', nested annexes, 68 buildings).
        Stored as varchar — `'2'` not `2` numerically.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

dw:BuildingType a mnf:SemanticType ;
    rdfs:label "Building Type Code" ;
    rdfs:comment """Three-value categorical. NB: 'RESIDENT', not
        'RESIDENTIAL' — a model writing the latter returns no rows.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "ACADEMIC" ;
        mnf:allowedValue "SERVICE" ;
        mnf:allowedValue "RESIDENT"
    ] .

dw:BuildingUse a mnf:SemanticType ;
    rdfs:label "Building Use Code (3-4 char)" ;
    rdfs:comment "Abbreviated codes; not human-friendly without a legend." ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "AER" ;
        mnf:allowedValue "DHOA" ;
        mnf:allowedValue "OTH" ;
        mnf:allowedValue "STAC" ;
        mnf:allowedValue "GAR"
    ] .

dw:OwnershipType a mnf:SemanticType ;
    rdfs:label "Building Ownership" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "OWNED" ;
        mnf:allowedValue "LEASED"
    ] .

dw:CampusSector a mnf:SemanticType ;
    rdfs:label "Campus Sector" ;
    rdfs:comment "Eight values; note 'WESTWEST' (not 'WEST WEST') and 'OFFCAMPUS' (not 'OFF CAMPUS')." ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "WEST" ;
        mnf:allowedValue "MAIN GROUP" ;
        mnf:allowedValue "OFFCAMPUS" ;
        mnf:allowedValue "EAST" ;
        mnf:allowedValue "NORTHWEST" ;
        mnf:allowedValue "NORTH" ;
        mnf:allowedValue "NORTHEAST" ;
        mnf:allowedValue "WESTWEST"
    ] .

dw:Site a mnf:SemanticType ;
    rdfs:label "MIT Site Code" ;
    rdfs:comment "Site code identifying the campus location. The main MIT campus is 'MIT'; satellite sites have other codes (Lincoln Lab, Bates, etc.)." ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        rdfs:comment "Observed values; codes are abbreviated." ;
        mnf:allowedValue "MIT" ;
        mnf:allowedValue "BATES" ;
        mnf:allowedValue "HAY" ;
        mnf:allowedValue "LINC" ;
        mnf:allowedValue "END" ;
        mnf:allowedValue "DC" ;
        mnf:allowedValue "BOS" ;
        mnf:allowedValue "WILM" ;
        mnf:allowedValue "HOLYOKE" ;
        mnf:allowedValue "MED"
    ] .

dw:AddressPurpose a mnf:SemanticType ;
    rdfs:label "Address-Purpose Code" ;
    rdfs:comment """13 distinct values. STREET is the physical-location
        address (242 of 242 buildings have one). MAIL is the mailing
        address (often '77 Massachusetts Ave' for central MIT delivery).
        E911_<n> are emergency-response addresses. PARCL<n> are property/
        parcel-records addresses. DELIVERY appears once.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "STREET" ;
        mnf:allowedValue "E911_1" ;
        mnf:allowedValue "MAIL" ;
        mnf:allowedValue "PARCL1" ;
        mnf:allowedValue "E911_2" ;
        mnf:allowedValue "PARCL2" ;
        mnf:allowedValue "PARCL3" ;
        mnf:allowedValue "E911_3" ;
        mnf:allowedValue "E911_4" ;
        mnf:allowedValue "E911_5" ;
        mnf:allowedValue "E911_6" ;
        mnf:allowedValue "DELIVERY" ;
        mnf:allowedValue "PARCL4"
    ] .

dw:MajorUseDesc a mnf:SemanticType ;
    rdfs:label "Major Use Description (8-char abbreviation)" ;
    rdfs:comment """Room categorisation codes from fclt_major_use. NB:
        codes are 8-char abbreviations, NOT human-friendly. Filtering on
        'Office' or 'Classroom' returns 0 rows; use 'OFFICES' / 'CLASSRMS'.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "OFFICES" ;
        mnf:allowedValue "CIRCULAT" ;
        mnf:allowedValue "RESIDENT" ;
        mnf:allowedValue "MECHANIC" ;
        mnf:allowedValue "LABS" ;
        mnf:allowedValue "BLDG SRV" ;
        mnf:allowedValue "GENERAL" ;
        mnf:allowedValue "SUPPORT" ;
        mnf:allowedValue "SPECIAL" ;
        mnf:allowedValue "CLASSRMS" ;
        mnf:allowedValue "STUDY" ;
        mnf:allowedValue "UNCLASS" ;
        mnf:allowedValue "HEALTH" ;
        mnf:allowedValue "ZUSE"
    ] .

dw:USPostalCodeStripped a mnf:SemanticType ;
    rdfs:label "US Postal Code, leading-zero stripped" ;
    rdfs:comment """[BVT-K-GAP-10] varchar storing the postal code with
        leading zeros REMOVED. Cambridge MA 02139 is stored as '2139'.
        Joining to zip_usa.ZIP_CODE requires zero-padding back.""" ;
    mnf:requiredPhysicalType mnf:Varchar .


# -----------------------------------------------------------------------------
# 3b. DW database catalogue (high-level, pseudo-dataset)
# -----------------------------------------------------------------------------

dw:DatabaseCatalogue a mnf:Dataset ;
    rdfs:label "dw — database-level catalogue (synthetic)" ;
    rdfs:comment """A synthetic "facts about DW" pseudo-dataset — captures
        the cluster taxonomy, the fac_*/fclt_* duality, prefix conventions,
        and per-table row counts that don't fit into any single real table.
        Stored conceptually in INFORMATION_SCHEMA + the dw_join_keys.json
        sidecar that ships with the upstream schema dump.

        Database shape (snapshot):
        * 97 tables, ~9.84M rows total
        * NO declared PKs / FKs in the upstream schema; all relationships
          are soft (annotated `mnf:declared false` in the FK records below)
        * 1,034 join-key pairs documented in upstream/dw_join_keys.json
        * 5 tables empty in this dump: estimated_surcharges_estonly,
          fund_center_hierarchy, opa_person_current, profit_center_group,
          subject_selector

        Cluster taxonomy:
        * Facilities (buildings, floors, rooms, space-*): ~24 tables
        * Subjects / courses / catalogues: ~16 tables
        * Library + TIP: ~9 tables
        * Moira / mailing lists: 5 tables
        * Departments / orgs: ~7 tables (DLC = Department / Lab / Center)
        * IAP (Independent Activities Period): 5 tables
        * People (employees / students / instructors): ~8 tables
        * Terms / academic calendar: 3 tables
        * Time dimensions: 4 tables
        * Geo (zip / domain lookups): 3 tables (zip_canada at 873K rows
          is surprisingly large)
        * Miscellaneous / staging / empty: ~13 tables

        Upstream-system prefix legend (the leading underscore-delimited
        token of a table name typically identifies its source system):
        * cip*   — Classification of Instructional Programs (federal)
        * cis_   — Course Information System
        * drupal_ — Drupal CMS (publishable mirror feeds)
        * frc_   — Financial Reporting Cube
        * hr_    — HR system
        * iap_   — Independent Activities Period
        * ir_    — Institutional Research
        * mit_   — MIT-specific directories
        * moira_ — Moira (Athena identity / mailing lists)
        * se_    — Student Engagement
        * sis_   — Student Information System
        * time_  — date dimensions
        * tip_   — Textbook Information Project
        * zpm_   — SAP ZPM module

        The fac_* / fclt_* duality (see dw:fac_fclt_duality):
        * `buildings` (211 rows): only addressable buildings, simple shape
        * `fac_*` family (~9 tables): keyed by BUILDING_KEY, plain style
        * `fclt_*` family (~13 tables + _hist): keyed by FCLT_BUILDING_KEY,
          richer / more denormalised
        * `fclt_*_hist` are SCD-2 history tables; `fclt_rooms_hist` is
          ~5M rows — by far the largest table in dw

        Schema interpretation: each row of this conceptual dataset is one
        table in dw. The columns below describe per-table structural facts.
        Narrative cluster / prefix / duality material that doesn't fit a
        tabular schema lives in this rdfs:comment.""" ;
    mnf:rowSemantics mnf:AggregateRow ;
    mnf:hasColumn
        dw:dwc_table_name , dw:dwc_row_count , dw:dwc_column_count ,
        dw:dwc_cluster , dw:dwc_is_empty ,
        dw:dwc_prefix_namespace ;
    mnf:hasPhysicalLayout bvtk:catalogue_pseudo_layout ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 97 ;
    mnf:hasKnownDeficiency
        dw:deficiency_no_declared_keys ,
        dw:deficiency_dw_dialect ,
        dw:deficiency_dw_unmodelled ,
        dw:deficiency_database_metadata_hack .

dw:dwc_table_name a mnf:Column ;
    mnf:columnName "table_name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:MySQLIdentifier ;
    mnf:nullable false .

dw:dwc_row_count a mnf:Column ;
    mnf:columnName "row_count" ;
    mnf:physicalType mnf:BigInt ;
    mnf:nullable true ;
    rdfs:comment "Snapshot row count in this dump." ;
    mnf:valueRange [ mnf:minInclusive 0 ] .

dw:dwc_column_count a mnf:Column ;
    mnf:columnName "column_count" ;
    mnf:physicalType mnf:Integer ;
    mnf:nullable true .

dw:dwc_cluster a mnf:Column ;
    mnf:columnName "cluster" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Conceptual cluster (Facilities / Subjects / Library / Moira / Departments / IAP / People / Terms / Time / Geo / Misc)." .

dw:dwc_is_empty a mnf:Column ;
    mnf:columnName "is_empty" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType bvtk:MySQLBoolean ;
    mnf:nullable false ;
    rdfs:comment "True for tables with row count 0 in this dump." .

dw:dwc_prefix_namespace a mnf:Column ;
    mnf:columnName "prefix_namespace" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Upstream-system prefix: cis_/drupal_/hr_/iap_/moira_/sis_/tip_/zpm_ etc." .


# -----------------------------------------------------------------------------
# 3c. DW facilities cluster — buildings
# -----------------------------------------------------------------------------

dw:buildings a mnf:Dataset ;
    rdfs:label "dw.buildings — addressable buildings (simple shape)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 211. Smallest of
        the three building tables. Includes only addressable buildings
        (no wings/annexes — those folded into parents). Carries
        BUILDING_STREET_ADDRESS denormalised.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:bld_building_key ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:bld_building_key , dw:bld_building_name ,
        dw:bld_building_street_address , dw:bld_bldg_gross_sqft ,
        dw:bld_bldg_assignable_sqft , dw:bld_building_counter ,
        dw:bld_warehouse_load_date ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/buildings" ;
    mnf:rowCountSnapshot 211 ;
    mnf:hasProvenance dw:dw_provenance .

dw:bld_building_key a mnf:Column ;
    mnf:columnName "BUILDING_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false ;
    rdfs:comment "PK; the MIT building number (e.g. 'NW32')." .

dw:bld_building_name a mnf:Column ;
    mnf:columnName "BUILDING_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment """[BVT-K-GAP-8] Proper-case canonical name ('Stata
        Center'). DIFFERENT style from fclt_building.BUILDING_NAME
        ('STATA CENTER' uppercase). See dw:building_name_disagreement.""" .

dw:bld_building_street_address a mnf:Column ;
    mnf:columnName "BUILDING_STREET_ADDRESS" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Denormalised onto buildings; for full address records use fclt_building_address." .

dw:bld_bldg_gross_sqft a mnf:Column ;
    mnf:columnName "BLDG_GROSS_SQUARE_FOOTAGE" ;
    mnf:physicalType mnf:Double ;
    mnf:nullable true ;
    mnf:unit "sqft" .

dw:bld_bldg_assignable_sqft a mnf:Column ;
    mnf:columnName "BLDG_ASSIGNABLE_SQUARE_FOOTAGE" ;
    mnf:physicalType mnf:Double ;
    mnf:nullable true ;
    mnf:unit "sqft" .

dw:bld_building_counter a mnf:Column ;
    mnf:columnName "BUILDING_COUNTER" ;
    mnf:physicalType mnf:Integer ;
    mnf:nullable true .

dw:bld_warehouse_load_date a mnf:Column ;
    mnf:columnName "WAREHOUSE_LOAD_DATE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:OracleShortDateString ;
    mnf:nullable true .


dw:fac_building a mnf:Dataset ;
    rdfs:label "dw.fac_building — buildings with rich attributes (FAC_-keyed)" ;
    rdfs:comment """[BVT-K-GAP-1 / BVT-K-GAP-11] Snapshot row count: 242.
        Same data as fclt_building on all 32 shared columns; differs
        only in PK column name (FAC_BUILDING_KEY vs FCLT_BUILDING_KEY).
        See dw:fac_fclt_duality.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:fac_building_key ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:fac_building_key , dw:fac_building_number , dw:fac_building_name ,
        dw:fac_building_name_long , dw:fac_building_named_for ,
        dw:fac_parent_building_number , dw:fac_building_type ,
        dw:fac_building_use , dw:fac_ownership_type ,
        dw:fac_campus_sector , dw:fac_site ,
        dw:fac_date_built , dw:fac_date_acquired , dw:fac_date_occupied ,
        dw:fac_warehouse_load_date_b ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/fac_building" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 242 ;
    mnf:hasKnownDeficiency dw:deficiency_dw_date_strings .

dw:fac_building_key a mnf:Column ;
    mnf:columnName "FAC_BUILDING_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false .

dw:fac_building_number a mnf:Column ;
    mnf:columnName "BUILDING_NUMBER" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false ;
    rdfs:comment "Equal to FAC_BUILDING_KEY in every row — see dw:building_key_identity." .

dw:fac_building_name a mnf:Column ;
    mnf:columnName "BUILDING_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-8] Uppercase short form ('STATA CENTER'). See dw:building_name_disagreement." .

dw:fac_building_name_long a mnf:Column ;
    mnf:columnName "BUILDING_NAME_LONG" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "[BVT-K-GAP-8] Formal full name ('Ray and Maria Stata Center'). Convention not perfectly consistent — for W64, BUILDING_NAME_LONG degrades to 'Building W64'." .

dw:fac_building_named_for a mnf:Column ;
    mnf:columnName "BUILDING_NAMED_FOR" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Real institutional names (NOT anonymised): 'Ray and Maria Stata', 'James H. and Marilyn Simons', etc." .

dw:fac_parent_building_number a mnf:Column ;
    mnf:columnName "PARENT_BUILDING_NUMBER" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable true ;
    rdfs:comment "Soft self-FK. NULL for 211 of 242 (the addressable wholes); set on the 31 wing/annex rows." .

dw:fac_building_type a mnf:Column ;
    mnf:columnName "BUILDING_TYPE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingType ;
    mnf:nullable true .

dw:fac_building_use a mnf:Column ;
    mnf:columnName "BUILDING_USE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingUse ;
    mnf:nullable true .

dw:fac_ownership_type a mnf:Column ;
    mnf:columnName "OWNERSHIP_TYPE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:OwnershipType ;
    mnf:nullable true .

dw:fac_campus_sector a mnf:Column ;
    mnf:columnName "CAMPUS_SECTOR" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:CampusSector ;
    mnf:nullable true .

dw:fac_site a mnf:Column ;
    mnf:columnName "SITE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:Site ;
    mnf:nullable true .

dw:fac_date_built a mnf:Column ;
    mnf:columnName "DATE_BUILT" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:USDateString ;
    mnf:nullable true ;
    rdfs:comment """[BVT-K-GAP-10] '07/01/1913' for the Simons Building.
        Filter for date ranges with `CAST(SUBSTR(DATE_BUILT,-4) AS UNSIGNED) < 1950`
        (returns 58 buildings).""" .

dw:fac_date_acquired a mnf:Column ;
    mnf:columnName "DATE_ACQUIRED" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:USDateString ;
    mnf:nullable true .

dw:fac_date_occupied a mnf:Column ;
    mnf:columnName "DATE_OCCUPIED" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:USDateString ;
    mnf:nullable true .

dw:fac_warehouse_load_date_b a mnf:Column ;
    mnf:columnName "WAREHOUSE_LOAD_DATE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType bvtk:OracleShortDateString ;
    mnf:nullable true .


dw:fclt_building a mnf:Dataset ;
    rdfs:label "dw.fclt_building — buildings with rich attributes (FCLT_-keyed)" ;
    rdfs:comment """Same 32 columns and same data as fac_building; differs
        only in PK column name (FCLT_BUILDING_KEY vs FAC_BUILDING_KEY). A
        SQL author can use either family; see dw:fac_fclt_duality.

        The 32 columns mirror fac_building. Only key columns are
        explicitly declared below; the other 28 are denoted by
        dw:fclt_building_columns_match_fac.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:fclt_building_key ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:fclt_building_key , dw:fclt_building_number ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/fclt_building" ;
    mnf:rowCountSnapshot 242 ;
    mnf:hasProvenance dw:dw_provenance .

dw:fclt_building_key a mnf:Column ;
    mnf:columnName "FCLT_BUILDING_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false .

dw:fclt_building_number a mnf:Column ;
    mnf:columnName "BUILDING_NUMBER" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false ;
    rdfs:comment "Equal to FCLT_BUILDING_KEY in every row — see dw:building_key_identity." .


# -----------------------------------------------------------------------------
# 3d. DW facilities cluster — addresses
# -----------------------------------------------------------------------------

dw:fclt_building_address a mnf:Dataset ;
    rdfs:label "dw.fclt_building_address — addresses by purpose (FCLT-keyed)" ;
    rdfs:comment """[BVT-K-GAP-1] Snapshot row count: 785. One row per
        (building, ADDRESS_PURPOSE). Composite key
        FCLT_BUILDING_ADDRESS_KEY = '<BUILDING>-<ADDRESS_PURPOSE>' (see
        dw:derive_fclt_address_key). [BVT-K-GAP-15]""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:fbla_address_key ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:fbla_address_key , dw:fbla_building_key , dw:fbla_address_purpose ,
        dw:fbla_street_number , dw:fbla_street_name , dw:fbla_street_suffix ,
        dw:fbla_pre_directional , dw:fbla_post_directional ,
        dw:fbla_city , dw:fbla_state , dw:fbla_postal_code ,
        dw:fbla_is_e911_address ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/fclt_building_address" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 785 ;
    mnf:hasKnownDeficiency dw:deficiency_postal_code_stripped .

dw:fbla_address_key a mnf:Column ;
    mnf:columnName "FCLT_BUILDING_ADDRESS_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "PK. Composite of BUILDING_NUMBER + ADDRESS_PURPOSE." .

dw:fbla_building_key a mnf:Column ;
    mnf:columnName "FCLT_BUILDING_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false ;
    rdfs:comment "[BVT-K-GAP-4] Soft FK to fclt_building.FCLT_BUILDING_KEY." .

dw:fbla_address_purpose a mnf:Column ;
    mnf:columnName "ADDRESS_PURPOSE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:AddressPurpose ;
    mnf:nullable false ;
    rdfs:comment "Discriminates address rows. Filter on the relevant value (e.g. ADDRESS_PURPOSE='STREET' for the physical street address)." .

dw:fbla_street_number a mnf:Column ;
    mnf:columnName "STREET_NUMBER" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:fbla_street_name a mnf:Column ;
    mnf:columnName "STREET_NAME" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Uppercase ('VASSAR')." .

dw:fbla_street_suffix a mnf:Column ;
    mnf:columnName "STREET_SUFFIX" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "2-3 letter abbrevs ('ST', 'AVE', 'BLVD')." .

dw:fbla_pre_directional a mnf:Column ;
    mnf:columnName "PRE_DIRECTIONAL" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Usually NULL." .

dw:fbla_post_directional a mnf:Column ;
    mnf:columnName "POST_DIRECTIONAL" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:fbla_city a mnf:Column ;
    mnf:columnName "CITY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:fbla_state a mnf:Column ;
    mnf:columnName "STATE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:fbla_postal_code a mnf:Column ;
    mnf:columnName "POSTAL_CODE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:USPostalCodeStripped ;
    mnf:nullable true .

dw:fbla_is_e911_address a mnf:Column ;
    mnf:columnName "IS_E911_ADDRESS" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Constant NULL in this dump — column exists, never populated. Don't filter on it." .

dw:fac_building_address a mnf:Dataset ;
    rdfs:label "dw.fac_building_address — addresses by purpose (FAC-keyed)" ;
    rdfs:comment """Parallel with fclt_building_address — same data,
        FAC-style key column names. The full table has 15 columns; only
        the heavily-trafficked key columns are explicitly declared here.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn dw:fba_building_key , dw:fba_address_purpose ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/fac_building_address" ;
    mnf:hasProvenance dw:dw_provenance ;
    mnf:rowCountSnapshot 785 ;
    mnf:hasKnownDeficiency dw:deficiency_postal_code_stripped .

dw:fba_building_key a mnf:Column ;
    mnf:columnName "BUILDING_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false .

dw:fba_address_purpose a mnf:Column ;
    mnf:columnName "ADDRESS_PURPOSE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:AddressPurpose ;
    mnf:nullable false .


# -----------------------------------------------------------------------------
# 3e. DW facilities cluster — rooms (3 parallel representations)
# -----------------------------------------------------------------------------

dw:fac_rooms a mnf:Dataset ;
    rdfs:label "dw.fac_rooms — room inventory (granular, includes service spaces)" ;
    rdfs:comment """[BVT-K-GAP-1 / BVT-K-GAP-14] Snapshot row count: 43,175.
        Includes service / circulation / mechanical spaces. ~2× the size
        of fclt_rooms because it has more granular space breakdown and
        collapses the Stata Center's letter-prefixed floors ('D4' →
        '1'). For "rooms a department occupies" prefer fclt_rooms; for
        "all rooms including circulation" prefer fac_rooms.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:entityKey dw:far_room_key ;
    mnf:schemaStability mnf:FixedSchema ;
    mnf:hasColumn
        dw:far_room_key , dw:far_building_key , dw:far_floor ,
        dw:far_floor_key , dw:far_room , dw:far_space_id ,
        dw:far_major_use_desc , dw:far_organization_name , dw:far_area ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/fac_rooms" ;
    mnf:rowCountSnapshot 43175 ;
    mnf:hasProvenance dw:dw_provenance .

dw:far_room_key a mnf:Column ;
    mnf:columnName "FAC_ROOM_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable false ;
    rdfs:comment "PK. = '<BUILDING_KEY>-<ROOM>'. See dw:derive_fac_room_key." .

dw:far_building_key a mnf:Column ;
    mnf:columnName "BUILDING_KEY" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType dw:BuildingNumber ;
    mnf:nullable false .

dw:far_floor a mnf:Column ;
