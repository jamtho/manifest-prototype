    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

dw:zip_usa__warehouse_load_date a mnf:Column ;
    mnf:columnName "WAREHOUSE_LOAD_DATE" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .


# =============================================================================
# PART 4: Cross-Cutting Physical Layout
# =============================================================================

bvtk:mysql_table_layout a mnf:PhysicalLayout ;
    mnf:fileFormat mnf:MySQLTable ;
    rdfs:comment "Live MySQL table accessed via connection. Path templates use mysql://{db}/{table}." .

bvtk:catalogue_pseudo_layout a mnf:PhysicalLayout ;
    mnf:fileFormat bvtk:DatabaseCatalogue ;
    rdfs:comment "[BVT-K-GAP-A] Pseudo-layout for dataset-of-facts representations." .

bvtk:DatabaseCatalogue a mnf:FileFormat ;
    rdfs:label "Database catalogue (INFORMATION_SCHEMA + sidecar)" ;
    rdfs:comment "Pseudo-format for a synthetic 'database overview' dataset." .
