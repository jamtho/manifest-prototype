        dw:isp_person_name , dw:isp_person_mit_affiliation ;
    mnf:hasPhysicalLayout bvtk:mysql_table_layout ;
    mnf:pathTemplate "mysql://dw/iap_subject_person" ;
    mnf:rowCountSnapshot 1113 ;
